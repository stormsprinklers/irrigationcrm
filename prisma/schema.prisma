  customerId       String
  currentStepIndex Int                      @default(0)
  /// Automation flow: current node (preferred over step index when flow nodes exist).
  currentNodeId    String?
  nextSendAt       DateTime
  status           CampaignEnrollmentStatus @default(ACTIVE)
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  campaign Campaign                 @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  customer Customer                 @relation(fields: [customerId], references: [id], onDelete: Cascade)
  events   CampaignEnrollmentEvent[]

  @@unique([campaignId, customerId])
  @@index([campaignId, status, nextSendAt])
  @@index([currentNodeId])
}

model CampaignFlowNode {
  id         String               @id @default(cuid())
  campaignId String
  type       CampaignFlowNodeType
  config     Json                 @default("{}")
  sortOrder  Int                  @default(0)
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, sortOrder])
}

model CampaignEnrollmentEvent {
  id           String   @id @default(cuid())
  enrollmentId String
  nodeId       String?
  eventType    String
  meta         Json?
  createdAt    DateTime @default(now())

  enrollment CampaignEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@index([enrollmentId, createdAt])
  @@index([nodeId])
}

model CampaignRecipient {
  id                String    @id @default(cuid())
  campaignId        String
  customerId        String?
  email             String?
  phone             String?
  status            String    @default("pending")
  sentAt            DateTime?
  deliveredAt       DateTime?
  openedAt          DateTime?
  clickedAt         DateTime?
  clickCount        Int       @default(0)
  error             String?
  sendgridMessageId String?
  twilioMessageSid  String?

  campaign Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([campaignId, status])
  @@index([twilioMessageSid])
}

model CallFlow {
  id                 String   @id @default(cuid())
  companyId          String
  name               String
  description        String?
  entryNodeId        String?
  afterHoursNodeId   String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  company      Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  nodes        CallFlowNode[]
  phoneNumbers PhoneNumber[]

  @@index([companyId])
}

model CallFlowNode {
  id        String           @id @default(cuid())
  flowId    String
  type      CallFlowNodeType
  config    Json             @default("{}")
  parentId  String?
  sortOrder Int              @default(0)

  flow CallFlow @relation(fields: [flowId], references: [id], onDelete: Cascade)

  @@index([flowId, sortOrder])
}

model AgentGroup {
  id              String        @id @default(cuid())
  companyId       String
  name            String
  ringStrategy    RingStrategy  @default(SIMULTANEOUS)
  ringTimeoutSec  Int           @default(30)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  company Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  members AgentGroupMember[]

  @@index([companyId])
}

model AgentGroupMember {
  groupId   String
  userId    String
  sortOrder Int @default(0)

  group AgentGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([groupId, userId])
}

model AgentPresence {
  userId     String              @id
  companyId  String
  status     AgentPresenceStatus @default(OFFLINE)
  lastSeenAt DateTime            @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([companyId, status])
}

model CallSession {
  id                   String            @id @default(cuid())
  companyId            String
  callSid              String            @unique
  /// Softphone (agent) CallSid once a CSR answers — used for hold/transfer.
  agentCallSid         String?
  conferenceSid        String?
  direction            CallDirection
  status               CallSessionStatus @default(RINGING)
  fromNumber           String
  toNumber             String
  customerId           String?
  assignedUserId       String?
  phoneNumberId        String?
  queueEnteredAt       DateTime?
  holdStartedAt        DateTime?
  transferType         TransferType?
  transferTargetUserId String?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  endedAt              DateTime?

  company        Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer       Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)
  assignedUser   User?        @relation("AssignedCallSessions", fields: [assignedUserId], references: [id], onDelete: SetNull)
  transferTarget User?        @relation("TransferTargetSessions", fields: [transferTargetUserId], references: [id], onDelete: SetNull)
  phoneNumber    PhoneNumber? @relation(fields: [phoneNumberId], references: [id], onDelete: SetNull)
  callLogs       CallLog[]
  visits         Visit[]
  callConversions CallConversion[]
  participants   CallParticipant[]

  @@index([companyId, status])
  @@index([assignedUserId])
  @@index([agentCallSid])
}

/// Live AI receptionist session for one Twilio CallSid.
model ReceptionistCall {
  id               String                 @id @default(cuid())
  companyId        String
  callSid          String                 @unique
  callSessionId    String?
  callLogId        String?
  flowId           String?
  nodeId           String?
  status           ReceptionistCallStatus @default(CONNECTING)
  fromE164         String
  toE164           String?
  customerId       String?
  conversationJson Json                   @default("{}")
  transcript       String                 @default("")
  summary          String?
  failureReason    String?
  startedAt        DateTime               @default(now())
  endedAt          DateTime?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  company  Company                   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer Customer?                 @relation(fields: [customerId], references: [id], onDelete: SetNull)
  holds    AppointmentHold[]
  tools    ReceptionistToolInvocation[]

  @@index([companyId, status])
  @@index([customerId])
}

/// Soft hold on a booking slot while the AI confirms details with the caller.
model AppointmentHold {
  id               String   @id @default(cuid())
  companyId        String
  receptionistCallId String?
  startAt          DateTime
  endAt            DateTime
  expiresAt        DateTime
  idempotencyKey   String
  createdAt        DateTime @default(now())

  company          Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  receptionistCall ReceptionistCall? @relation(fields: [receptionistCallId], references: [id], onDelete: SetNull)

  @@unique([companyId, idempotencyKey])
  @@index([companyId, startAt, endAt])
  @@index([expiresAt])
}

model ReceptionistToolInvocation {
  id                 String   @id @default(cuid())
  companyId          String
  receptionistCallId String
  tool               String
  argsHash           String
  resultCode         String
  latencyMs          Int      @default(0)
  idempotencyKey     String?
  errorMessage       String?
  createdAt          DateTime @default(now())

  company          Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  receptionistCall ReceptionistCall @relation(fields: [receptionistCallId], references: [id], onDelete: Cascade)

  @@unique([companyId, idempotencyKey])
  @@index([receptionistCallId, createdAt])
  @@index([companyId, tool])
}

/// Employees who joined a call (answered, softphone transfer, or personal-phone transfer).
model CallParticipant {
  id            String    @id @default(cuid())
  companyId     String
  callSessionId String
  callLogId     String?
  userId        String?
  displayName   String?
  phoneE164     String?
  /// ANSWERED | AGENT_TRANSFER | EXTERNAL_TRANSFER
  role          String
  joinedAt      DateTime  @default(now())
  leftAt        DateTime?

  company     Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  callSession CallSession @relation(fields: [callSessionId], references: [id], onDelete: Cascade)
  callLog     CallLog?    @relation(fields: [callLogId], references: [id], onDelete: SetNull)
  user        User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([callSessionId, joinedAt])
  @@index([callLogId])
  @@index([companyId, userId])
}

model Conversation {
  id               String   @id @default(cuid())
  companyId        String
  channel          Channel
  scope            Scope
  customerId       String?
  participantPhone String?
  participantMetaId String?
  title            String?
  lastMessageAt    DateTime @default(now())
  createdAt        DateTime @default(now())

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  messages Message[]

  @@index([companyId, channel, scope, lastMessageAt])
  @@index([companyId, channel, participantMetaId])
}

model Message {
  id               String           @id @default(cuid())
  conversationId   String
  senderId         String?
  direction        MessageDirection
  body             String
  twilioMessageSid String?          @unique
  metaMessageId    String?          @unique
  deliveryStatus   String?
  sentAt           DateTime         @default(now())
  readAt           DateTime?
  contactInfoDetected Boolean       @default(false)
  parsedContactInfo   Json?
  contactInfoAppliedAt DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User?        @relation(fields: [senderId], references: [id], onDelete: SetNull)
  media        MessageMedia[]

  @@index([conversationId, sentAt])
}

model MessageMedia {
  id        String   @id @default(cuid())
  messageId String
  blobUrl   String
  fileName  String?
  mimeType  String
  sizeBytes Int?
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
}

model EmailMessage {
  id         String      @id @default(cuid())
  companyId  String
  scope      Scope
  folder     EmailFolder @default(INBOX)
  fromEmail  String
  toEmails   String[]
  ccEmails   String[]    @default([])
  subject    String
  bodyHtml   String?
  bodyText   String?
  customerId String?
  userId     String?
  sendgridId String?
  threadId   String?
  isRead     Boolean     @default(false)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  user     User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  attachments EmailAttachment[]

  @@index([companyId, scope, folder, createdAt])
}

model EmailAttachment {
  id             String   @id @default(cuid())
  emailMessageId String
  blobUrl        String
  fileName       String
  mimeType       String
  sizeBytes      Int?
  createdAt      DateTime @default(now())

  emailMessage EmailMessage @relation(fields: [emailMessageId], references: [id], onDelete: Cascade)

  @@index([emailMessageId])
}

model InternalGroup {
  id        String   @id @default(cuid())
  companyId String
  name      String
  createdAt DateTime @default(now())

  company Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  members InternalGroupMember[]
}

model InternalGroupMember {
  id      String @id @default(cuid())
  groupId String
  userId  String

  group InternalGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
}

model ServiceArea {
  id        String   @id @default(cuid())
  companyId String
  name      String
  slug      String
  color     String   @default("#2563EB")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  zips    ServiceAreaZip[]
  users   UserServiceArea[]
  visits  Visit[]

  @@unique([companyId, slug])
  @@index([companyId, sortOrder])
}

model PartsSupplier {
  id            String    @id @default(cuid())
  companyId     String
  name          String
  googlePlaceId String?
  address       String?
  city          String?
  state         String?
  zip           String?
  latitude      Float?
  longitude     Float?
  phone         String?
  hoursJson     Json?
  weekdayHours  String[]  @default([])
  timezone      String?
  isActive      Boolean   @default(true)
  sortOrder     Int       @default(0)
  lastSyncedAt  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, googlePlaceId])
  @@index([companyId, isActive, sortOrder])
}

model ServiceAreaZip {
  id            String @id @default(cuid())
  serviceAreaId String
  zipCode       String

  serviceArea ServiceArea @relation(fields: [serviceAreaId], references: [id], onDelete: Cascade)

  @@unique([serviceAreaId, zipCode])
  @@index([zipCode])
}

model UserServiceArea {
  id            String @id @default(cuid())
  userId        String
  serviceAreaId String

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  serviceArea ServiceArea @relation(fields: [serviceAreaId], references: [id], onDelete: Cascade)

  @@unique([userId, serviceAreaId])
}

model Crew {
  id            String    @id @default(cuid())
  companyId     String
  name          String
  color         String    @default("#16A34A")
  division      Division?
  /// Schedule Day column avatar; typically a crew member.
  foremanUserId String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  company Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  foreman User?        @relation("CrewForeman", fields: [foremanUserId], references: [id], onDelete: SetNull)
  members CrewMember[]
  visits  Visit[]

  @@index([companyId])
  @@index([foremanUserId])
}

model CrewMember {
  id     String @id @default(cuid())
  crewId String
  userId String

  crew Crew @relation(fields: [crewId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([crewId, userId])
}

model Visit {
  id             String      @id @default(cuid())
  companyId      String
  customerId     String?
  propertyId     String?
  title          String
  startAt        DateTime
  endAt          DateTime
  division       Division
  serviceAreaId  String?
  assignedUserId String?
  crewId         String?
  /// Staff user who created the visit (self-scheduled field jobs).
  createdByUserId String?
  status         VisitStatus @default(SCHEDULED)
  tags           String[]    @default([])
  workSummary    String?     @db.Text
  isCallback     Boolean     @default(false)
  address        String?
  city           String?
  state          String?
  zip            String?
  enRouteEtaSeconds     Int?
  enRouteEtaAt          DateTime?
  enRouteCalculatedAt   DateTime?
  enRouteOriginLat      Decimal?  @db.Decimal(10, 7)
  enRouteOriginLng      Decimal?  @db.Decimal(10, 7)
  maintenancePlanVisitId String?     @unique
  callSessionId          String?
  designProjectId        String?
  designVersionId        String?
  designExportMetadata   Json?
  installDurationDays    Int?
  estimateId             String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  company              Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer             Customer?               @relation(fields: [customerId], references: [id], onDelete: SetNull)
  property             CustomerProperty?       @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  serviceArea          ServiceArea?            @relation(fields: [serviceAreaId], references: [id], onDelete: SetNull)
  assignedUser         User?                   @relation("AssignedVisits", fields: [assignedUserId], references: [id], onDelete: SetNull)
  createdByUser        User?                   @relation("CreatedVisits", fields: [createdByUserId], references: [id], onDelete: SetNull)
  crew                 Crew?                   @relation(fields: [crewId], references: [id], onDelete: SetNull)
  maintenancePlanVisit MaintenancePlanVisit?   @relation(fields: [maintenancePlanVisitId], references: [id], onDelete: SetNull)
  timeEvents   VisitTimeEvent[]
  techTimeSegments TechTimeSegment[]
  lineItems    VisitLineItem[]
  notes        VisitNote[]
  attachments  VisitAttachment[]
  discounts    Discount[]        @relation("VisitDiscounts")
  estimates    Estimate[]
  invoices     Invoice[]
  callLogs     CallLog[]         @relation("CallLogVisit")
  callConversions CallConversion[]
  callSession  CallSession?      @relation(fields: [callSessionId], references: [id], onDelete: SetNull)
  visitChecklists VisitChecklist[]
  notificationJobs NotificationJob[]
  feedbackSurveyResponses FeedbackSurveyResponse[]
  feedbackSurveyTokens FeedbackSurveyToken[]

  @@index([companyId, startAt])
  @@index([serviceAreaId])
  @@index([assignedUserId])
  @@index([createdByUserId])
  @@index([crewId])
  @@index([customerId])
  @@map("ScheduledJob")
}

model VisitTimeEvent {
  id         String        @id @default(cuid())
  visitId    String
  userId     String
  type       TimeEventType
  occurredAt DateTime      @default(now())

  visit Visit @relation(fields: [visitId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([visitId, occurredAt])
}

model VisitLineItem {
  id              String   @id @default(cuid())
  visitId         String
  priceBookItemId String?
  name            String
  description     String?
  quantity        Decimal  @default(1) @db.Decimal(10, 2)
  unitPrice       Decimal  @db.Decimal(10, 2)
  unitCost        Decimal? @db.Decimal(10, 2)
  total           Decimal  @db.Decimal(10, 2)
  sortOrder       Int      @default(0)

  visit         Visit          @relation(fields: [visitId], references: [id], onDelete: Cascade)
  priceBookItem PriceBookItem? @relation(fields: [priceBookItemId], references: [id], onDelete: SetNull)

  @@index([visitId])
}

model TimeClockEntry {
  id         String    @id @default(cuid())
  companyId  String
  userId     String
  clockInAt  DateTime
  clockOutAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([companyId, clockInAt])
  @@index([userId, clockInAt])
}

enum TechTimeCategory {
  DRIVING
  WORKING
  PARTS_RUN
  BREAK
  SHOP
  TRAINING_MEETING
}

enum TechTimeSegmentSource {
  MOBILE
  WEB
  SYSTEM
}

model TechTimeSegment {
  id        String                @id @default(cuid())
  companyId String
  userId    String
  category  TechTimeCategory
  visitId   String?
  startedAt DateTime
  endedAt   DateTime?
  source    TechTimeSegmentSource @default(MOBILE)
  deviceId  String?
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  visit   Visit?  @relation(fields: [visitId], references: [id], onDelete: SetNull)
  corrections TechTimeCorrection[]

  @@index([companyId, userId, startedAt])
  @@index([userId, endedAt])
  @@index([visitId])
}

enum TechTimeCorrectionStatus {
  PENDING
  APPROVED
  REJECTED
}

model TechTimeCorrection {
  id              String                   @id @default(cuid())
  companyId       String
  segmentId       String
  requestedById   String
  reviewedById    String?
  status          TechTimeCorrectionStatus @default(PENDING)
  requestedStart  DateTime?
  requestedEnd    DateTime?
  requestedCategory TechTimeCategory?
  note            String?                  @db.Text
  reviewNote      String?                  @db.Text
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  company     Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  segment     TechTimeSegment @relation(fields: [segmentId], references: [id], onDelete: Cascade)
  requestedBy User            @relation("TechTimeCorrectionRequester", fields: [requestedById], references: [id], onDelete: Cascade)
  reviewedBy  User?           @relation("TechTimeCorrectionReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([companyId, status])
  @@index([segmentId])
}

model StaffAuditLog {
  id         String   @id @default(cuid())
  companyId  String
  actorId    String
  deviceId   String?
  entityType String
  entityId   String
  action     String
  field      String?
  before     Json?
  after      Json?
  customerId String?
  propertyId String?
  visitId    String?
  createdAt  DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  actor   User    @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@index([companyId, createdAt])
  @@index([entityType, entityId])
  @@index([actorId, createdAt])
  @@index([visitId])
  @@index([customerId])
}

model EmployeeWorkSchedule {
  id        String   @id @default(cuid())
  companyId String
  userId    String
  dayOfWeek Int
  isWorking Boolean  @default(true)
  startTime String?
  endTime   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dayOfWeek])
  @@index([companyId])
}

model TimeOffRequest {
  id            String        @id @default(cuid())
  companyId     String
  userId        String
  startAt       DateTime
  endAt         DateTime
  allDay        Boolean       @default(true)
  type          TimeOffType   @default(TIME_OFF)
  status        TimeOffStatus @default(PENDING)
  reason        String?
  reviewNotes   String?
  reviewedById  String?
  reviewedAt    DateTime?
  createdById   String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  company    Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user       User    @relation("TimeOffEmployee", fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy User?   @relation("TimeOffReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  createdBy  User    @relation("TimeOffCreator", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([companyId, startAt])
  @@index([userId, startAt])
  @@index([companyId, status])
}

model VisitNote {
  id        String   @id @default(cuid())
  visitId   String
  authorId  String
  body      String
  /// Optional linked call (recording / transcript / AI summary appear on the note).
  callLogId String?
  createdAt DateTime @default(now())

  visit   Visit    @relation(fields: [visitId], references: [id], onDelete: Cascade)
  author  User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  callLog CallLog? @relation(fields: [callLogId], references: [id], onDelete: SetNull)

  @@index([visitId, createdAt])
  @@index([callLogId])
}

model VisitAttachment {
  id           String   @id @default(cuid())
  visitId      String
  uploadedById String
  blobUrl      String
  fileName     String
  mimeType     String
  createdAt    DateTime @default(now())

  visit      Visit @relation(fields: [visitId], references: [id], onDelete: Cascade)
  uploadedBy User  @relation(fields: [uploadedById], references: [id], onDelete: Cascade)

  @@index([visitId])
}

model Discount {
  id         String       @id @default(cuid())
  visitId    String?
  estimateId String?
  /// When set, discount applies only to that estimate option.
  optionId   String?
  label      String?
  type       DiscountType
  amount     Decimal      @db.Decimal(10, 2)

  visit    Visit?          @relation("VisitDiscounts", fields: [visitId], references: [id], onDelete: Cascade)
  estimate Estimate?       @relation("EstimateDiscounts", fields: [estimateId], references: [id], onDelete: Cascade)
  option   EstimateOption? @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@index([visitId])
  @@index([estimateId])
  @@index([optionId])
}

model PriceBookCategory {
  id        String            @id @default(cuid())
  companyId String
  type      PriceBookItemType @default(SERVICE)
  name      String
  slug      String
  parentId  String?
  sortOrder Int               @default(0)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  company  Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parent   PriceBookCategory?  @relation("PriceBookCategoryTree", fields: [parentId], references: [id], onDelete: Cascade)
