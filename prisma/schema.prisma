  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  company              Company                    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  referredBy           Customer?                  @relation("CustomerReferrals", fields: [referredByCustomerId], references: [id], onDelete: SetNull)
  referredCustomers    Customer[]                 @relation("CustomerReferrals")
  referralMember       ReferralMember?
  referralSubmissionsAsReferrer ReferralSubmission[] @relation("ReferrerCustomer")
  referralSubmissionsAsReferred ReferralSubmission[] @relation("ReferredCustomer")
  blockedEntry         BlockedContact?
  callLogs             CallLog[]
  callConversions      CallConversion[]
  receptionistCalls    ReceptionistCall[]
  conversations        Conversation[]
  emailMessages        EmailMessage[]
  properties           CustomerProperty[]
  visits               Visit[]
  estimates            Estimate[]
  invoices             Invoice[]
  maintenanceEnrollments MaintenancePlanEnrollment[]
  convertedFromLead      Lead?
  callSessions           CallSession[]
  contactListMembers     ContactListMember[]
  campaignRecipients     CampaignRecipient[]
  campaignEnrollments    CampaignEnrollment[]
  phones                 CustomerPhone[]
  notes                  CustomerNote[]
  attachments            CustomerAttachment[]
  portalLoginTokens      CustomerPortalLoginToken[]
  notificationDeliveries NotificationDelivery[]
  feedbackSurveyResponses FeedbackSurveyResponse[]
  marketingTouchEvents   MarketingTouchEvent[]

  @@index([referredByCustomerId])
  @@index([companyId, attributionChannel])
  @@index([companyId, createdAt])
}

