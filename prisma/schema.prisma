  @@index([userId])
  @@index([companyId])
}

/// Browser / iOS Home Screen PWA push subscriptions (Web Push + VAPID).
model WebPushSubscription {
  id        String   @id @default(cuid())
  userId    String
  companyId String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([companyId])
}

model IntegrationCredential {
  id         String           @id @default(cuid())
  companyId  String
  type       IntegrationType
  label      String
  keyHash    String
  keyPrefix  String
  enabled    Boolean          @default(true)
  lastUsedAt DateTime?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, type])
}

model IntegrationAuditLog {
  id              String           @id @default(cuid())
  companyId       String
  integrationType IntegrationType?
  action          String
  payloadHash     String?
  status          String
  error           String?
  createdAt       DateTime         @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, createdAt])
}

model MetaWebhookEvent {
  id        String   @id @default(cuid())
  companyId String
  object    String?
  field     String?
  payload   Json
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, createdAt])
}

model SocialPost {
  id          String    @id @default(cuid())
  companyId   String
  platform    String
  externalId  String
  postType    String    @default("post")
  caption     String?
  permalink   String?
  publishedAt DateTime?
  likes       Int       @default(0)
  comments    Int       @default(0)
  shares      Int       @default(0)
  reach       Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, platform, externalId])
  @@index([companyId, publishedAt])
}

enum SocialPostSubmissionStatus {
  DRAFT
  PENDING_REVIEW
  REVISION_REQUESTED
  APPROVED
  SCHEDULED
  PUBLISHING
  PUBLISHED
  REJECTED
  FAILED
}

model SocialPostSubmission {
  id             String                     @id @default(cuid())
  companyId      String
  platform       String
  postType       String                     @default("post")
  caption        String?
  status         SocialPostSubmissionStatus @default(DRAFT)
  scheduledAt    DateTime?
  publishedAt    DateTime?
  submittedAt    DateTime?
  approvedAt     DateTime?
  rejectedAt     DateTime?
  reviewedAt     DateTime?
  externalPostId String?
  permalink      String?
  publishError   String?
  copiedFromId   String?
  createdById    String
  reviewedById   String?
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt

  company    Company                     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy  User                        @relation("SocialSubmissionAuthor", fields: [createdById], references: [id], onDelete: Cascade)
  reviewedBy User?                       @relation("SocialSubmissionReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  copiedFrom SocialPostSubmission?       @relation("SocialSubmissionCopy", fields: [copiedFromId], references: [id], onDelete: SetNull)
  copies     SocialPostSubmission[]      @relation("SocialSubmissionCopy")
  media      SocialPostSubmissionMedia[]
  comments   SocialPostReviewComment[]

  @@index([companyId, status])
  @@index([companyId, scheduledAt])
  @@index([createdById, status])
}

model SocialPostSubmissionMedia {
  id           String   @id @default(cuid())
  submissionId String
  blobUrl      String
  fileName     String
  mimeType     String
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())

  submission SocialPostSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId, sortOrder])
}

model SocialPostReviewComment {
  id                String   @id @default(cuid())
  submissionId      String
  authorId          String
  body              String
  isRevisionRequest Boolean  @default(false)
  createdAt         DateTime @default(now())

  submission SocialPostSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  author     User                 @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([submissionId, createdAt])
}

model MarketingEvent {
  id         String   @id @default(cuid())
  companyId  String
  source     String   @default("WEBSITE")
  eventType  String
  externalId String?
  sessionId  String?
  pagePath   String?
  metadata   Json?
  occurredAt DateTime
  createdAt  DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, source, externalId])
  @@index([companyId, eventType, occurredAt])
}

/// Immutable first-party attribution audit log for every marketing touch.
model MarketingTouchEvent {
  id                String   @id @default(cuid())
  companyId         String
  customerId        String?
  leadId            String?
  callLogId         String?
  conversationId    String?
  sessionId         String?
  eventType         String
  channel           String
  source            String?
  medium            String?
  campaign          String?
  term              String?
  content           String?
  gclid             String?
  fbclid            String?
  msclkid           String?
  trackingSource    String?
  phone             String?
  pagePath          String?
  occurredAt        DateTime
  metadata          Json?
  createdAt         DateTime @default(now())

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer     Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  lead         Lead?         @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([companyId, occurredAt])
  @@index([companyId, channel])
  @@index([companyId, sessionId])
  @@index([customerId, occurredAt])
  @@index([leadId, occurredAt])
  @@index([companyId, phone])
  @@map("marketing_touch_events")
}

/// Daily paid-media spend snapshot for CAC / ROAS (populated by cron).
model MarketingSpendDaily {
  id          String                @id @default(cuid())
  companyId   String
  date        DateTime              @db.Date
  channel     MarketingSpendChannel
  spend       Decimal               @db.Decimal(12, 2)
  impressions Int?
  clicks      Int?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, date, channel])
  @@index([companyId, date])
  @@map("marketing_spend_daily")
}

model GbpReviewSlackDelivery {
  id         String   @id @default(cuid())
  companyId  String
  reviewId   String
  reviewName String?
  starRating Int?
  deliveredAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, reviewId])
  @@index([companyId, deliveredAt])
}

/// Tracks Google reviews already pushed to staff (Radar PWA / in-app).
model GbpReviewStaffNotify {
  id          String   @id @default(cuid())
  companyId   String
  reviewId    String
  notifiedAt  DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, reviewId])
  @@index([companyId, notifiedAt])
}

model ReferralProgramSettings {
  id                  String   @id @default(cuid())
  companyId           String   @unique
  enabled             Boolean  @default(false)
  installRewardCents  Int      @default(25000)
  serviceRewardCents  Int      @default(5000)
  autoEnrollCustomers Boolean  @default(false)
  headline            String?
  terms               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model ReferralMember {
  id                        String    @id @default(cuid())
  companyId                 String
  customerId                String    @unique
  token                     String    @unique
  enrolledAt                DateTime  @default(now())
  stripeConnectAccountId    String?
  stripeConnectOnboardedAt  DateTime?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model ReferralSubmission {
  id                  String                   @id @default(cuid())
  companyId           String
  referrerCustomerId  String
  referredName        String
  referredPhone       String?
  referredEmail       String?
  referredAddress     String?
  referredCity        String?
  referredState       String?
  referredZip         String?
  leadId              String?                  @unique
  referredCustomerId  String?
  visitId             String?
  estimateId          String?
  invoiceId           String?
  status              ReferralSubmissionStatus @default(SUBMITTED)
  division            Division?
  revenueCents        Int?
