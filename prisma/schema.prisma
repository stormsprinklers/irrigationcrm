generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  CSR
  TECH
}

enum CustomerStatus {
  ACTIVE
  ARCHIVED
}

enum Scope {
  EXTERNAL
  INTERNAL
}

enum Channel {
  SMS
  INTERNAL_CHAT
  EMAIL
}

enum CallDirection {
  INBOUND
  OUTBOUND
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum EmailFolder {
  INBOX
  SENT
  DRAFT
  ARCHIVE
  SPAM
  TRASH
}

enum Division {
  INSTALL
  SERVICE
}

enum EmployeeStatus {
  ACTIVE
  ARCHIVED
}

enum TimeOffStatus {
  PENDING
  APPROVED
  DENIED
  CANCELLED
}

enum TimeOffType {
  TIME_OFF
  PTO
  SICK
  OTHER
}

enum PayType {
  HOURLY
  COMMISSION
  HYBRID
  SALARY
}

enum CommissionBasis {
  COMPLETED_JOB_REVENUE
  COLLECTED_INVOICE
  GROSS_PROFIT
  LABOR_ONLY
}

enum PayPeriodType {
  WEEKLY
  BIWEEKLY
  MONTHLY
}

enum HousecallProMigrationStatus {
  DRAFT
  IN_PROGRESS
  PAUSED
  COMPLETED
  FAILED
}

enum HousecallProMigrationStepStatus {
  PENDING
  RUNNING
  PAUSED
  COMPLETED
  FAILED
  SKIPPED
}

enum HousecallProMigrationStepType {
  CONNECT
  TAGS
  SERVICE_ZONES
  EMPLOYEES
  MATERIAL_CATEGORIES
  MATERIALS
  PRICE_BOOK_SERVICES
  CUSTOMERS
  CUSTOMER_ATTACHMENTS
  JOBS
  JOB_ATTACHMENTS
  ESTIMATES
  ESTIMATE_ATTACHMENTS
  INVOICES
  SCHEDULE_WINDOWS
}

enum HcpEntityType {
  TAG
  SERVICE_ZONE
  EMPLOYEE
  MATERIAL_CATEGORY
  MATERIAL
  SERVICE
  CUSTOMER
  PROPERTY
  VISIT
  ESTIMATE
  INVOICE
  ATTACHMENT
}

enum VisitStatus {
  UNSCHEDULED
  SCHEDULED
  EN_ROUTE
  IN_PROGRESS
  PAUSED
  COMPLETED
  CANCELLED
}

enum ChecklistItemType {
  PASS_FLAG_FAIL
  NUMBER
  NOTE
  MEDIA
  MULTI_SELECT
  CHECKBOX
  SELECT_ONE
}

enum VisitChecklistStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum TimeEventType {
  EN_ROUTE
  START
  PAUSE
  RESUME
  FINISH
}

enum EstimateStatus {
  DRAFT
  SENT
  APPROVED
  EXPIRED
  DECLINED
  CONVERTED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  PARTIAL
  REFUNDED
  VOID
}

enum DiscountType {
  PERCENT
  FIXED
}

enum DepositType {
  PERCENT
  FIXED
}

enum PaymentMethod {
  STRIPE
  CASH
  CHECK
  OTHER
}

enum BillingFrequency {
  MONTHLY
  QUARTERLY
  ANNUAL
  MULTI_YEAR_UPFRONT
}

enum PlanDurationType {
  FIXED_TERM
  UNTIL_CANCELLED
}

enum EnrollmentStatus {
  DRAFT
  SENT
  ACTIVE
  PENDING_RENEWAL
  RENEWED
  EXPIRING_SOON
  EXPIRED
  CANCELLED
}

enum PlanVisitSeason {
  SPRING
  SUMMER
  FALL
  CUSTOM
}

enum PlanVisitStatus {
  UNSCHEDULED
  SCHEDULED
  COMPLETED
  SKIPPED
  OVERDUE
}

enum BillingPeriodStatus {
  PENDING
  DUE
  PAID
  FAILED
  CANCELLED
  WAIVED
}

enum CancellationFeeType {
  NONE
  FIXED
  PERCENT
}

enum PlanDiscountAppliesTo {
  PLAN_PRICE
  VISIT_LABOR
  ALL_JOBS
}

enum SmartControllerProvider {
  RACHIO
  HYDRAWISE
}

enum SmartControllerStatus {
  DISCONNECTED
  CONNECTED
  ERROR
}

enum PriceBookItemType {
  SERVICE
  MATERIAL
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  WON
  LOST
}

enum PriceBookDiscountAppliesTo {
  ALL
  SERVICES
  MATERIALS
}

enum PriceBookPricingMode {
  MANUAL
  CALCULATED
}

enum RingStrategy {
  SIMULTANEOUS
  ROUND_ROBIN
  SEQUENTIAL
}

enum AgentPresenceStatus {
  AVAILABLE
  ON_CALL
  AWAY
  OFFLINE
}

enum CallSessionStatus {
  RINGING
  IN_PROGRESS
  ON_HOLD
  TRANSFERRING
  COMPLETED
}

enum TransferType {
  COLD
  WARM
}

enum CallFlowNodeType {
  DIAL_GROUP
  IVR
  QUEUE
  FORWARD
  VOICEMAIL
  HANGUP
}

enum PhoneNumberType {
  PRIMARY
  TRACKING
  AGENT_DIRECT
}

enum CallDisposition {
  NONE
  BOOKED
  NOT_BOOKED
  NON_OPPORTUNITY
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum CampaignType {
  BLAST
  DRIP
}

enum CampaignEnrollmentStatus {
  ACTIVE
  COMPLETED
  PAUSED
  CANCELLED
}

enum CampaignChannel {
  SMS
  EMAIL
}

model Company {
  id                       String   @id @default(cuid())
  name                     String
  address                  String?
  city                     String?
  state                    String?
  zip                      String?
  timezone                 String?  @default("America/Denver")
  supportEmail             String?
  phone                    String?
  website                  String?
  legalName                String?
  industry                 String?
  description              String?
  twilioPhone              String?
  sendgridFrom             String?
  sendgridInboundDomain    String?
  emailSenderName          String?
  emailLogoUrl             String?
  recordCalls              Boolean  @default(true)
  transcribeCalls          Boolean  @default(true)
  estimateExpiryDays       Int      @default(14)
  estimateDepositRequired  Boolean  @default(false)
  estimateDepositType      DepositType?
  estimateDepositAmount    Decimal? @db.Decimal(10, 2)
  invoicePrefix            String?  @default("INV")
  invoiceTerms             String?
  invoiceFooter            String?
  onlineBookingEnabled     Boolean  @default(false)
  bookingSlug              String?
  bookingLeadTimeHours     Int      @default(24)
  portalEnabled            Boolean  @default(false)
  portalShowInvoices       Boolean  @default(true)
  portalShowEstimates      Boolean  @default(true)
  portalShowJobs           Boolean  @default(true)
  portalSlug               String?
  portalRescheduleLeadHours Int     @default(24)
  portalCancelLeadHours    Int      @default(24)
  portalAllowSchedule      Boolean  @default(true)
  portalShowMaintenance    Boolean  @default(true)
  portalShowChecklists     Boolean  @default(true)
  portalShowRachio         Boolean  @default(true)
  portalShowOffers         Boolean  @default(true)
  portalRachioAllowRun     Boolean  @default(false)
  notifyEstimateSent       Boolean  @default(true)
  notifyInvoicePaid        Boolean  @default(true)
  notifyVisitScheduled     Boolean  @default(true)
  notifyVisitEnRoute       Boolean  @default(true)
  leadSources              String[] @default([])
  intakeRequiredFields     String[] @default([])
  businessHours            Json?
  referralCode             String?
  subscriptionTier         String?  @default("Professional")
  customReportPresets      Json?
  rachioApiKey             String?
  rachioPersonId           String?
  hydrawiseApiKey          String?
  googleBusinessRefreshToken   String?
  googleBusinessAccountId      String?
  googleBusinessLocationId     String?
  googleBusinessLocationTitle  String?
  googleBusinessConnectedAt    DateTime?
  googleBusinessCatalogJson    Json?
  metaWebhookVerifyToken       String?   @unique
  metaAppSecret                String?
  metaPageId                   String?
  metaInstagramAccountId        String?
  metaWebhookVerifiedAt        DateTime?
  defaultLeadAssigneeId    String?
  notifyLeadCreated        Boolean  @default(true)
  flatRatePricingEnabled   Boolean  @default(false)
  materialMarkupsEnabled   Boolean  @default(true)
  commissionBasis          CommissionBasis @default(COMPLETED_JOB_REVENUE)
  payPeriodType            PayPeriodType   @default(BIWEEKLY)
  payPeriodAnchorDate      DateTime?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  defaultLeadAssignee    User?                    @relation("DefaultLeadAssignee", fields: [defaultLeadAssigneeId], references: [id], onDelete: SetNull)
  users                  User[]
  customers              Customer[]
  customerPhones         CustomerPhone[]
  blockedContacts        BlockedContact[]
  callLogs               CallLog[]
  conversations          Conversation[]
  emailMessages          EmailMessage[]
  internalGroups         InternalGroup[]
  serviceAreas           ServiceArea[]
  crews                  Crew[]
  visits                 Visit[]
  properties             CustomerProperty[]
  priceBookCategories    PriceBookCategory[]
  priceBookDiscounts     PriceBookDiscount[]
  estimateTemplates      EstimateTemplate[]
  pricingForms           PricingForm[]
  leads                  Lead[]
  estimates              Estimate[]
  invoices               Invoice[]
  maintenancePlans       MaintenancePlanTemplate[]
  maintenanceEnrollments MaintenancePlanEnrollment[]
  phoneNumbers           PhoneNumber[]
  callFlows              CallFlow[]
  agentGroups            AgentGroup[]
  agentPresences         AgentPresence[]
  callSessions           CallSession[]
  laborRates             LaborRate[]
  materialMarkupTiers    MaterialMarkupTier[]
  timeClockEntries       TimeClockEntry[]
  voiceClips             VoiceClip[]
  notificationTemplates  NotificationTemplate[]
  notificationRules      NotificationRule[]
  contactLists           ContactList[]
  campaigns              Campaign[]
  housecallProMigrations HousecallProMigration[]
  hcpEntityMappings      HcpEntityMapping[]
  employeeWorkSchedules  EmployeeWorkSchedule[]
  timeOffRequests        TimeOffRequest[]
  checklistTemplates     ChecklistTemplate[]
  portalLoginTokens      CustomerPortalLoginToken[]
  portalOffers           PortalOffer[]
  integrationCredentials IntegrationCredential[]
  metaWebhookEvents      MetaWebhookEvent[]
  integrationAuditLogs   IntegrationAuditLog[]
  marketingEvents        MarketingEvent[]
}

model User {
  id           String         @id @default(cuid())
  companyId    String
  name         String
  email        String         @unique
  passwordHash String?
  phone        String?
  role         UserRole       @default(CSR)
  title        String?
  status       EmployeeStatus @default(ACTIVE)
  division     Division?
  color        String?
  photoUrl     String?
  address      String?
  city         String?
  state        String?
  zip          String?
  birthDate    DateTime?
  tags         String[]       @default([])
  payType            PayType?
  hourlyRate         Decimal?       @db.Decimal(10, 2)
  commissionPercent  Decimal?       @db.Decimal(5, 2)
  annualSalary       Decimal?       @db.Decimal(12, 2)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  company            Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  callLogs           CallLog[]
  sentMessages       Message[]
  emailMessages      EmailMessage[]
  blockedContacts    BlockedContact[]     @relation("BlockedByUser")
  groupMemberships   InternalGroupMember[]
  serviceAreas       UserServiceArea[]
  crewMemberships    CrewMember[]
  assignedVisits     Visit[]              @relation("AssignedVisits")
  assignedLeads      Lead[]               @relation("AssignedLeads")
  defaultLeadFor     Company[]            @relation("DefaultLeadAssignee")
  visitTimeEvents    VisitTimeEvent[]
  visitNotes         VisitNote[]
  visitAttachments   VisitAttachment[]
  customerNotes      CustomerNote[]
  customerAttachments CustomerAttachment[]
  agentPresence      AgentPresence?
  agentGroupMembers  AgentGroupMember[]
  assignedCallSessions CallSession[] @relation("AssignedCallSessions")
  transferTargetSessions CallSession[] @relation("TransferTargetSessions")
  timeClockEntries       TimeClockEntry[]
  assignedPhoneNumbers   PhoneNumber[]        @relation("AssignedPhoneNumbers")
  handledCallLogs        CallLog[]            @relation("HandledCallLogs")
  workScheduleDays       EmployeeWorkSchedule[]
  timeOffRequests        TimeOffRequest[]     @relation("TimeOffEmployee")
  reviewedTimeOff        TimeOffRequest[]     @relation("TimeOffReviewer")
  createdTimeOff         TimeOffRequest[]     @relation("TimeOffCreator")
  lmsUserId              String?              @unique
  lmsSyncStatus          String?
  lmsLastSyncedAt        DateTime?
}

model Customer {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  phone       String?
  email       String?
  companyName String?
  address     String?
  city        String?
  state       String?
  zip         String?
  leadSource       String?
  stripeCustomerId String?
  status           CustomerStatus @default(ACTIVE)
  doNotService     Boolean        @default(false)
  tags             String[]       @default([])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  company              Company                    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  blockedEntry         BlockedContact?
  callLogs             CallLog[]
  conversations        Conversation[]
  emailMessages        EmailMessage[]
  properties           CustomerProperty[]
  visits               Visit[]
  estimates            Estimate[]
  invoices             Invoice[]
  maintenanceEnrollments MaintenancePlanEnrollment[]
  convertedFromLead      Lead?
  callSessions           CallSession[]
  contactListMembers     ContactListMember[]
  campaignRecipients     CampaignRecipient[]
  campaignEnrollments    CampaignEnrollment[]
  phones                 CustomerPhone[]
  notes                  CustomerNote[]
  attachments            CustomerAttachment[]
  portalLoginTokens      CustomerPortalLoginToken[]
}

model CustomerPhone {
  id         String   @id @default(cuid())
  companyId  String
  customerId String
  phone      String
  note       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([companyId, phone])
  @@index([customerId])
}

model CustomerNote {
  id         String   @id @default(cuid())
  customerId String
  authorId   String
  body       String
  createdAt  DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  author   User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([customerId, createdAt])
}

model CustomerAttachment {
  id           String   @id @default(cuid())
  customerId   String
  uploadedById String
  blobUrl      String
  fileName     String
  mimeType     String
  createdAt    DateTime @default(now())

  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  uploadedBy User     @relation(fields: [uploadedById], references: [id], onDelete: Cascade)

  @@index([customerId])
}

model Lead {
  id                  String     @id @default(cuid())
  companyId           String
  name                String
  phone               String?
  email               String?
  source              String?
  status              LeadStatus @default(NEW)
  assignedUserId      String?
  notes               String?
  externalId          String?
  metadata            Json?
  convertedCustomerId String?    @unique
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  company           Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assignedUser      User?     @relation("AssignedLeads", fields: [assignedUserId], references: [id], onDelete: SetNull)
  convertedCustomer Customer? @relation(fields: [convertedCustomerId], references: [id], onDelete: SetNull)
  callLogs          CallLog[]

  @@unique([companyId, externalId])
  @@index([companyId, status])
  @@index([assignedUserId])
}

model CustomerProperty {
  id         String   @id @default(cuid())
  companyId  String
  customerId String
  name       String
  address    String?
  city       String?
  state      String?
  zip        String?
  isPrimary  Boolean  @default(false)
  propertyDiagramUrl String?
  latitude   Float?
  longitude  Float?
  mapBounds  Json?
  aerialImageUrl    String?
  stylizedImageUrl  String?
  irrigationZoneCount     Int?
  shutoffValveLocation    String?
  controllerLocation      String?
  irrigationWizardStep Int?
  irrigationMapStatus  IrrigationMapStatus?
  designProjectId      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  company          Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer         Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  visits           Visit[]
  estimates        Estimate[]
  maintenancePlans MaintenancePlanEnrollment[]
  smartControllers PropertySmartController[]
  irrigationZones  PropertyIrrigationZone[]
  irrigationMapZones PropertyIrrigationMapZone[]
  irrigationValves   PropertyIrrigationValve[]
  irrigationControllers PropertyIrrigationController[]

  @@index([companyId, customerId])
}

model BlockedContact {
  id         String   @id @default(cuid())
  companyId  String
  customerId String?  @unique
  phone      String?
  email      String?
  blockedAt  DateTime @default(now())
  blockedBy  String
  reason     String?

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  user     User      @relation("BlockedByUser", fields: [blockedBy], references: [id])

  @@index([companyId, phone])
  @@index([companyId, email])
}

model CallLog {
  id            String        @id @default(cuid())
  companyId     String
  scope         Scope
  direction     CallDirection
  fromNumber    String
  toNumber      String
  customerId    String?
  userId        String?
  sessionId     String?
  conferenceSid String?
  queueWaitSec  Int?
  twilioCallSid String        @unique
  status        String
  durationSec   Int?
  recordingUrl  String?
  transcript    String?
  disposition   CallDisposition @default(NONE)
  dispositionNote String?
  visitId       String?
  leadId        String?
  handledByUserId String?
  startedAt     DateTime      @default(now())
  endedAt       DateTime?

  company  Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)
  user     User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  session  CallSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  visit    Visit?       @relation("CallLogVisit", fields: [visitId], references: [id], onDelete: SetNull)
  lead     Lead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)
  handledBy User?       @relation("HandledCallLogs", fields: [handledByUserId], references: [id], onDelete: SetNull)

  @@index([companyId, scope, startedAt])
  @@index([sessionId])
  @@index([disposition])
}

model PhoneNumber {
  id             String          @id @default(cuid())
  companyId      String
  e164           String
  friendlyName   String?
  numberType     PhoneNumberType @default(TRACKING)
  isPrimary      Boolean         @default(false)
  callFlowId     String?
  assignedUserId String?
  trackingSource String?
  twilioSid      String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  company      Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  callFlow     CallFlow?    @relation(fields: [callFlowId], references: [id], onDelete: SetNull)
  assignedUser User?        @relation("AssignedPhoneNumbers", fields: [assignedUserId], references: [id], onDelete: SetNull)
  callSessions CallSession[]

  @@unique([companyId, e164])
  @@index([companyId])
}

model VoiceClip {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  blobUrl     String
  mimeType    String
  durationSec Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model NotificationTemplate {
  id        String  @id @default(cuid())
  companyId String
  channel   Channel
  slug      String
  name      String
  subject   String?
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  rules   NotificationRule[]

  @@unique([companyId, slug, channel])
  @@index([companyId])
}

model NotificationRule {
  id         String  @id @default(cuid())
  companyId  String
  event      String
  templateId String
  enabled    Boolean @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  company  Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  template NotificationTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([companyId, event, templateId])
  @@index([companyId, event])
}

model ContactList {
  id        String   @id @default(cuid())
  companyId String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company  Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  members  ContactListMember[]
  campaigns Campaign[]

  @@index([companyId])
}

model ContactListMember {
  id         String  @id @default(cuid())
  listId     String
  customerId String?
  email      String?
  phone      String?
  name       String?

  list     ContactList @relation(fields: [listId], references: [id], onDelete: Cascade)
  customer Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([listId])
}

model Campaign {
  id              String          @id @default(cuid())
  companyId       String
  name            String
  type            CampaignType    @default(BLAST)
  channel         CampaignChannel
  status          CampaignStatus  @default(DRAFT)
  subject         String?
  bodyHtml        String?
  bodyText        String
  listId          String?
  audienceFilters Json?
  aiPrompt        String?
  dripSettings    Json?
  scheduledAt     DateTime?
  sentAt          DateTime?
  statsJson       Json?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  company     Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  list        ContactList?         @relation(fields: [listId], references: [id], onDelete: SetNull)
  recipients  CampaignRecipient[]
  steps       CampaignStep[]
  enrollments CampaignEnrollment[]

  @@index([companyId, status])
}

model CampaignStep {
  id         String          @id @default(cuid())
  campaignId String
  sortOrder  Int
  channel    CampaignChannel
  subject    String?
  bodyHtml   String?
  bodyText   String
  delayDays  Int             @default(0)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, sortOrder])
}

model CampaignEnrollment {
  id               String                   @id @default(cuid())
  campaignId       String
  customerId       String
  currentStepIndex Int                      @default(0)
  nextSendAt       DateTime
  status           CampaignEnrollmentStatus @default(ACTIVE)
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([campaignId, customerId])
  @@index([campaignId, status, nextSendAt])
}

model CampaignRecipient {
  id                String    @id @default(cuid())
  campaignId        String
  customerId        String?
  email             String?
  phone             String?
  status            String    @default("pending")
  sentAt            DateTime?
  deliveredAt       DateTime?
  openedAt          DateTime?
  clickedAt         DateTime?
  clickCount        Int       @default(0)
  error             String?
  sendgridMessageId String?
  twilioMessageSid  String?

  campaign Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([campaignId, status])
  @@index([twilioMessageSid])
}

model CallFlow {
  id                 String   @id @default(cuid())
  companyId          String
  name               String
  description        String?
  entryNodeId        String?
  afterHoursNodeId   String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  company      Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  nodes        CallFlowNode[]
  phoneNumbers PhoneNumber[]

  @@index([companyId])
}

model CallFlowNode {
  id        String           @id @default(cuid())
  flowId    String
  type      CallFlowNodeType
  config    Json             @default("{}")
  parentId  String?
  sortOrder Int              @default(0)

  flow CallFlow @relation(fields: [flowId], references: [id], onDelete: Cascade)

  @@index([flowId, sortOrder])
}

model AgentGroup {
  id              String        @id @default(cuid())
  companyId       String
  name            String
