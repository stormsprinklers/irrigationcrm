model Company {
  id                       String   @id @default(cuid())
  name                     String
  address                  String?
  city                     String?
  state                    String?
  zip                      String?
  timezone                 String?  @default("America/Denver")
  supportEmail             String?
  phone                    String?
  website                  String?
  /// Public URL for company Terms of Service (iOS, receipts, portal).
  termsOfServiceUrl        String?
  /// Public URL for company Privacy Policy (iOS, receipts, portal).
  privacyPolicyUrl         String?
  legalName                String?
  industry                 String?
  description              String?
  twilioPhone              String?
  sendgridFrom             String?
  sendgridInboundDomain    String?
  emailSenderName          String?
  emailLogoUrl             String?
  recordCalls              Boolean  @default(true)
  transcribeCalls          Boolean  @default(true)
  /// When true (default), known customers skip entry IVR / spam gate and ring agents directly.
  skipIvrForKnownCustomers Boolean  @default(true)
  /// Audio clip played while callers wait in the company queue (required for production queue).
  queueWaitClipId          String?
  /// Audio clip played when a CSR puts a live call on hold.
  holdMusicClipId          String?
  estimateExpiryDays       Int      @default(14)
  estimateDepositRequired  Boolean  @default(false)
  estimateDepositType      DepositType?
  estimateDepositAmount    Decimal? @db.Decimal(10, 2)
  /// After estimate approval, when work is booked for another day: require a deposit if visit total exceeds this amount (USD).
  deferredVisitDepositThreshold Decimal @default(1000) @db.Decimal(10, 2)
  /// Percent of visit total to collect as deposit when over the deferred-visit threshold (e.g. 50 = 50%).
  deferredVisitDepositPercent   Decimal @default(50) @db.Decimal(5, 2)
  /// Customer-facing warranty copy shown on sent estimate links.
  estimateWarrantyText     String?  @db.Text
  defaultInstallDurationDays Int    @default(4)
  supplierEmail            String?
  supplierPartsAutoSend    Boolean  @default(false)
  invoicePrefix            String?  @default("INV")
  /// Prefix for human-readable estimate numbers (e.g. EST-1012).
  estimatePrefix           String?  @default("EST")
  /// Next sequential integer used when minting estimate numbers (atomic increment).
  estimateNextNumber       Int      @default(1)
  invoiceTerms             String?
  invoiceFooter            String?
  onlineBookingEnabled     Boolean  @default(false)
  bookingSlug              String?
  bookingLeadTimeHours     Int      @default(24)
  portalEnabled            Boolean  @default(false)
  portalShowInvoices       Boolean  @default(true)
  portalShowEstimates      Boolean  @default(true)
  portalShowJobs           Boolean  @default(true)
  portalSlug               String?
  portalRescheduleLeadHours Int     @default(24)
  portalCancelLeadHours    Int      @default(24)
  portalAllowSchedule      Boolean  @default(true)
  portalShowMaintenance    Boolean  @default(true)
  portalShowChecklists     Boolean  @default(true)
  /// When true, visit UI presents all applied checklists as one combined checklist.
  mergeVisitChecklists     Boolean  @default(false)
  portalShowRachio         Boolean  @default(true)
  portalShowOffers         Boolean  @default(true)
  portalShowReferrals      Boolean  @default(true)
  portalRachioAllowRun     Boolean  @default(false)
  notifyEstimateSent       Boolean  @default(true)
  notifyInvoicePaid        Boolean  @default(true)
  /// Customer email/SMS when a Stripe Checkout / card payment fails, with retry link.
  notifyInvoicePaymentFailed Boolean @default(true)
  notifyVisitScheduled     Boolean  @default(true)
  notifyVisitEnRoute       Boolean  @default(true)
  notifyVisitEnRouteIncludeTechnicianPhoto Boolean @default(false)
  notifyVisitTimeUpdated   Boolean  @default(true)
  notifyVisitCancelled     Boolean  @default(true)
  notifyVisitCompleted     Boolean  @default(true)
  notifyReviewRequest      Boolean  @default(true)
  notifyFeedbackSurvey     Boolean  @default(true)
  notifyEstimateFollowUp   Boolean  @default(false)
  googleReviewUrl          String?
  websiteBaseUrl           String?
  arrivalWindowHours       Int      @default(3)
  /// When true, schedule Day view shows dashed open booking windows.
  openTimeSlotsEnabled     Boolean  @default(true)
  /// Per-division booking windows: { SERVICE: [{start,end}], INSTALL: [...] }
  divisionBookingWindows   Json?
  feedbackSurveyDelayHours Int      @default(24)
  reviewRequestDelayHours  Int      @default(2)
  estimateFollowUpIntervalDays Int  @default(3)
  leadSources              String[] @default([])
  /// Soft-removed lead sources kept for history / filters.
  archivedLeadSources      String[] @default([])
  intakeRequiredFields     String[] @default([])
  /// Days before today that field techs may access customer SMS (assigned visits).
  techSmsPastDays          Int      @default(7)
  /// Days after today that field techs may access customer SMS (assigned visits).
  techSmsFutureDays        Int      @default(7)
  businessHours            Json?
  referralCode             String?
  stripeConnectAccountId   String?
  subscriptionTier         String?  @default("Professional")
  customReportPresets      Json?
  rachioApiKey             String?
  rachioPersonId           String?
  hydrawiseApiKey          String?
  googleBusinessRefreshToken   String?
  googleBusinessAccountId      String?
  googleBusinessLocationId     String?
  googleBusinessLocationTitle  String?
  organicSearchWebsiteUrl      String?
  googleBusinessConnectedAt    DateTime?
  googleBusinessCatalogJson    Json?
  googleSearchConsoleRefreshToken String?
  googleSearchConsoleSiteUrl      String?
  googleSearchConsoleConnectedAt  DateTime?
  googleAdsRefreshToken           String?
  googleAdsCustomerId             String?
  googleAdsCustomerName           String?
  googleAdsLoginCustomerId        String?
  googleAdsConnectedAt            DateTime?
  // @deprecated GA4 CRM OAuth — use native website analytics. See lib/google-analytics/DEPRECATED.md
  googleAnalyticsRefreshToken     String?
  googleAnalyticsPropertyId       String?
  googleAnalyticsConnectedAt      DateTime?
  metaWebhookVerifyToken       String?   @unique
  metaAppId                    String?
  metaAppSecret                String?
  metaPageId                   String?
  metaInstagramAccountId        String?
  metaPageAccessToken          String?
  metaSocialSyncedAt           DateTime?
  metaSocialMetricsJson        Json?
  metaWebhookVerifiedAt        DateTime?
  metaAdsAccessToken           String?
  metaAdAccountId              String?
  metaAdAccountName            String?
  metaAdsConnectedAt           DateTime?
  slackGbpReviewsEnabled       Boolean  @default(false)
  slackGbpReviewsChannelId     String?
  slackGbpReviewsBootstrapped  Boolean  @default(false)
  outboundCommsDisabled        Boolean  @default(false)
  outboundCommsDisabledReason  String?
  outboundCommsDisabledAt      DateTime?
  outboundCommsDisabledById    String?
  /// Feature flag: AI receptionist call-flow node may connect Media Streams.
  aiReceptionistEnabled        Boolean  @default(false)
  aiReceptionistMaxMinutes     Int      @default(12)
  aiReceptionistSmsConfirm     Boolean  @default(true)
  /// Optional prompt overrides for the AI receptionist (tone, policies, FAQ/knowledge).
  aiReceptionistTone           String?  @db.Text
  aiReceptionistPolicies       String?  @db.Text
  aiReceptionistKnowledge      String?  @db.Text
  defaultLeadAssigneeId    String?
  notifyLeadCreated        Boolean  @default(true)
  flatRatePricingEnabled   Boolean  @default(false)
  materialMarkupsEnabled   Boolean  @default(true)
  /// Stripe Issuing expense cards program for this company.
  expenseCardsEnabled      Boolean  @default(false)
  /// Default spend limits and card controls (daily/monthly cents, block flags, MCC allowlist).
  expenseCardDefaultsJson  Json?
  commissionBasis          CommissionBasis @default(COMPLETED_JOB_REVENUE)
  payPeriodType            PayPeriodType   @default(BIWEEKLY)
  payPeriodAnchorDate      DateTime?
  defaultTechnicianPayType           PayType  @default(HYBRID)
  defaultTechnicianHourlyRate        Decimal  @default(25) @db.Decimal(10, 2)
  defaultTechnicianCommissionPercent Decimal  @default(20) @db.Decimal(5, 2)
  overtimeWeeklyThresholdHours       Decimal  @default(40) @db.Decimal(5, 2)
  overtimeRateMultiplier             Decimal  @default(1.5) @db.Decimal(4, 2)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  defaultLeadAssignee    User?                    @relation("DefaultLeadAssignee", fields: [defaultLeadAssigneeId], references: [id], onDelete: SetNull)
  users                  User[]
  customers              Customer[]
  customerPhones         CustomerPhone[]
  blockedContacts        BlockedContact[]
  callLogs               CallLog[]
  callConversions        CallConversion[]
  conversations          Conversation[]
  emailMessages          EmailMessage[]
  internalGroups         InternalGroup[]
  serviceAreas           ServiceArea[]
  partsSuppliers         PartsSupplier[]
  crews                  Crew[]
  visits                 Visit[]
  properties             CustomerProperty[]
  priceBookCategories    PriceBookCategory[]
  priceBookDiscounts     PriceBookDiscount[]
  estimateTemplates      EstimateTemplate[]
  pricingForms           PricingForm[]
  leads                  Lead[]
  estimates              Estimate[]
  invoices               Invoice[]
  maintenancePlans       MaintenancePlanTemplate[]
  maintenanceEnrollments MaintenancePlanEnrollment[]
  phoneNumbers           PhoneNumber[]
  callFlows              CallFlow[]
  agentGroups            AgentGroup[]
  agentPresences         AgentPresence[]
  callSessions           CallSession[]
  callParticipants       CallParticipant[]
  receptionistCalls      ReceptionistCall[]
  appointmentHolds       AppointmentHold[]
  receptionistToolInvocations ReceptionistToolInvocation[]
  laborRates             LaborRate[]
  materialMarkupTiers    MaterialMarkupTier[]
  timeClockEntries       TimeClockEntry[]
  techTimeSegments       TechTimeSegment[]
  techTimeCorrections    TechTimeCorrection[]
  expenseCardRolePolicies ExpenseCardRolePolicy[]
  expenseCards           ExpenseCard[]
  staffAuditLogs         StaffAuditLog[]
  voiceClips             VoiceClip[]
  queueWaitClip          VoiceClip?  @relation("CompanyQueueWaitClip", fields: [queueWaitClipId], references: [id], onDelete: SetNull)
  holdMusicClip          VoiceClip?  @relation("CompanyHoldMusicClip", fields: [holdMusicClipId], references: [id], onDelete: SetNull)
  appNotifications       AppNotification[]
  notificationTemplates  NotificationTemplate[]
  notificationRules      NotificationRule[]
  notificationDeliveries NotificationDelivery[]
  notificationJobs       NotificationJob[]
  contactLists           ContactList[]
  campaigns              Campaign[]
  housecallProMigrations HousecallProMigration[]
  hcpEntityMappings      HcpEntityMapping[]
  employeeWorkSchedules  EmployeeWorkSchedule[]
  timeOffRequests        TimeOffRequest[]
  checklistTemplates     ChecklistTemplate[]
  portalLoginTokens      CustomerPortalLoginToken[]
  portalOffers           PortalOffer[]
  integrationCredentials IntegrationCredential[]
  mobileSessions         MobileSession[]
  mobilePushDevices      MobilePushDevice[]
  webPushSubscriptions   WebPushSubscription[]
  metaWebhookEvents      MetaWebhookEvent[]
  socialPosts            SocialPost[]
  socialPostSubmissions  SocialPostSubmission[]
  integrationAuditLogs   IntegrationAuditLog[]
  marketingEvents        MarketingEvent[]
  gbpReviewSlackDeliveries GbpReviewSlackDelivery[]
  gbpReviewStaffNotifies   GbpReviewStaffNotify[]
  localSeoKeywords     LocalSeoKeyword[]
  localSeoTargetCities LocalSeoTargetCity[]
  localSeoSerpSearches LocalSeoSerpSearch[]
  localSeoRankingCaches LocalSeoRankingCache[]
  seoTasks               SeoTask[]
  referralProgramSettings ReferralProgramSettings?
  referralMembers        ReferralMember[]
  referralSubmissions    ReferralSubmission[]
  jobApplicants          JobApplicant[]
  hiringRoleAssignments  HiringRoleAssignment[]
  hiringManagerAvailabilities HiringManagerAvailability[]
  hiringScreenBookings   HiringScreenBooking[]
  marketingTouchEvents   MarketingTouchEvent[]
  marketingSpendDaily    MarketingSpendDaily[]
  vehicles               Vehicle[]
}

model LocalSeoSerpSearch {
  id        String   @id @default(cuid())
  companyId String
  endpoint  String
  keyword   String?
  cityId    String?
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([companyId, createdAt])
  @@index([endpoint, createdAt])
}

model LocalSeoRankingCache {
  id            String           @id @default(cuid())
  companyId     String
  channel       LocalSeoChannel  @default(GBP)
  keyword       String
  cityId        String
  ourRank       Int?
  topBusinesses Json
  fetchedAt     DateTime         @default(now())

  company Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  city    LocalSeoTargetCity @relation(fields: [cityId], references: [id], onDelete: Cascade)

  @@unique([companyId, channel, keyword, cityId])
  @@index([companyId, channel, keyword])
}

enum LocalSeoChannel {
  GBP
  ORGANIC
}

model LocalSeoKeyword {
  id        String          @id @default(cuid())
  companyId String
  channel   LocalSeoChannel @default(GBP)
  keyword   String
  sortOrder Int             @default(0)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, channel, keyword])
  @@index([companyId, channel])
}

model LocalSeoTargetCity {
  id            String   @id @default(cuid())
  companyId     String
  serpApiId     String?
  googleId      Int?
  name          String
  canonicalName String
  countryCode   String   @default("US")
  targetType    String   @default("City")
  latitude      Float
  longitude     Float
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  rankingCaches LocalSeoRankingCache[]

  @@unique([companyId, canonicalName])
  @@index([companyId])
}

model SeoTask {
  id          String    @id @default(cuid())
  companyId   String
  title       String
  description String    @db.Text
  category    String?
  rationale   String?   @db.Text
  priority    Int       @default(1)
  completed   Boolean   @default(false)
  completedAt DateTime?
  source      String    @default("ai")
  batchId     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, completed, createdAt])
  @@index([companyId, batchId])
}

model User {
  id           String         @id @default(cuid())
  companyId    String
  firstName    String         @default("")
  lastName     String         @default("")
  name         String
  email        String         @unique
  passwordHash String?
  phone        String?
  role         UserRole       @default(CSR)
  title        String?
  status       EmployeeStatus @default(ACTIVE)
  division     Division?
  color        String?
  photoUrl     String?
  websiteTeamSlug String?
  address      String?
  city         String?
  state        String?
  zip          String?
  birthDate    DateTime?
  tags         String[]       @default([])
  /// When set (e.g. AI_RECEPTIONIST), this is a non-login system account for automated notes.
  systemKind   String?
  /// App Store review / Apple demo technician — no phone or MFA required; disable via Integrations.
  appleDemoAccount Boolean @default(false)
  payType            PayType?
  hourlyRate         Decimal?       @db.Decimal(10, 2)
  commissionPercent  Decimal?       @db.Decimal(5, 2)
  annualSalary       Decimal?       @db.Decimal(12, 2)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  company            Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  callLogs           CallLog[]
  sentMessages       Message[]
  emailMessages      EmailMessage[]
  blockedContacts    BlockedContact[]     @relation("BlockedByUser")
  groupMemberships   InternalGroupMember[]
  serviceAreas       UserServiceArea[]
  crewMemberships    CrewMember[]
  crewsAsForeman     Crew[]               @relation("CrewForeman")
  assignedVisits     Visit[]              @relation("AssignedVisits")
  createdVisits      Visit[]              @relation("CreatedVisits")
  assignedLeads      Lead[]               @relation("AssignedLeads")
  mobileSessions     MobileSession[]
  mobilePushDevices  MobilePushDevice[]
  webPushSubscriptions WebPushSubscription[]
  defaultLeadFor     Company[]            @relation("DefaultLeadAssignee")
  visitTimeEvents    VisitTimeEvent[]
  visitNotes         VisitNote[]
  visitAttachments   VisitAttachment[]
  customerNotes      CustomerNote[]
  customerAttachments CustomerAttachment[]
  agentPresence      AgentPresence?
  agentGroupMembers  AgentGroupMember[]
  assignedCallSessions CallSession[] @relation("AssignedCallSessions")
  transferTargetSessions CallSession[] @relation("TransferTargetSessions")
  timeClockEntries       TimeClockEntry[]
  techTimeSegments       TechTimeSegment[]
  techTimeCorrections    TechTimeCorrection[] @relation("TechTimeCorrectionRequester")
  reviewedTimeCorrections TechTimeCorrection[] @relation("TechTimeCorrectionReviewer")
  staffAuditLogs         StaffAuditLog[]
  assignedPhoneNumbers   PhoneNumber[]        @relation("AssignedPhoneNumbers")
  handledCallLogs        CallLog[]            @relation("HandledCallLogs")
  answeredCallConversions CallConversion[]    @relation("AnsweredCallConversions")
  callParticipants         CallParticipant[]
  workScheduleDays       EmployeeWorkSchedule[]
  timeOffRequests        TimeOffRequest[]     @relation("TimeOffEmployee")
  reviewedTimeOff        TimeOffRequest[]     @relation("TimeOffReviewer")
  createdTimeOff         TimeOffRequest[]     @relation("TimeOffCreator")
  lmsUserId              String?              @unique
  lmsSyncStatus          String?
  lmsLastSyncedAt        DateTime?
  socialPostSubmissions  SocialPostSubmission[] @relation("SocialSubmissionAuthor")
  reviewedSocialPosts    SocialPostSubmission[] @relation("SocialSubmissionReviewer")
  socialPostReviewComments SocialPostReviewComment[]
  appNotifications         AppNotification[]
  hiringRoleAssignments    HiringRoleAssignment[] @relation("HiringRoleManager")
  hiringManagerAvailability HiringManagerAvailability?
  hiringScreenBookings     HiringScreenBooking[]  @relation("HiringScreenManager")
  assignedVehicles         Vehicle[]              @relation("VehicleAssignee")
  vehicleAttachments       VehicleAttachment[]
  vehicleMileageLogs       VehicleMileageLog[]
  vehicleServiceRecords    VehicleServiceRecord[] @relation("VehicleServicePerformer")
  reportedVehicleIssues    VehicleIssue[]         @relation("VehicleIssueReporter")
  resolvedVehicleIssues    VehicleIssue[]         @relation("VehicleIssueResolver")
  authMfaChallenges        AuthMfaChallenge[]
  passwordResetTokens      PasswordResetToken[]
  expenseCard              ExpenseCard?
  createdExpenseCards      ExpenseCard[] @relation("ExpenseCardCreator")
}

enum AuthMfaPurpose {
  LOGIN
  MOBILE_LOGIN
  LMS_LOGIN
  EXPENSE_CARD_ADMIN
}

enum ExpenseCardStatus {
  ACTIVE
  INACTIVE
  CANCELED
}

/// Role-level defaults for Stripe Issuing expense cards (limits + controls).
model ExpenseCardRolePolicy {
  id                 String   @id @default(cuid())
  companyId          String
  role               UserRole
  dailyLimitCents    Int?
  monthlyLimitCents  Int?
  blockAtm           Boolean?
  blockInternational Boolean?
  blockOnline        Boolean?
  /// Stripe MCC / category codes allowlist (empty = inherit company defaults).
  allowedCategories  String[] @default([])
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, role])
  @@index([companyId])
}

/// Maps an employee to a Stripe Issuing virtual card. Never stores PAN/CVC/PIN.
model ExpenseCard {
  id                   String            @id @default(cuid())
  companyId            String
  userId               String            @unique
  stripeCardholderId   String
  stripeCardId         String            @unique
  status               ExpenseCardStatus @default(ACTIVE)
  last4                String?
  /// Per-employee overrides; null inherits role → company defaults.
  dailyLimitCents      Int?
  monthlyLimitCents    Int?
  blockAtm             Boolean?
  blockInternational   Boolean?
  blockOnline          Boolean?
  allowedCategories    String[]          @default([])
  createdByUserId      String?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdBy User?   @relation("ExpenseCardCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([companyId, status])
  @@index([stripeCardId])
}

/// Short-lived SMS OTP challenge for staff sign-in (CRM, mobile, LMS).
model AuthMfaChallenge {
  id          String         @id @default(cuid())
  userId      String
  purpose     AuthMfaPurpose
  codeHash    String
  phoneMasked String
  attempts    Int            @default(0)
  expiresAt   DateTime
  verifiedAt  DateTime?
  consumedAt  DateTime?
  createdAt   DateTime       @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Customer {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  phone       String?
  email       String?
  companyName String?
  address     String?
  city        String?
  state       String?
  zip         String?
  leadSource       String?
  /// Normalized first-touch marketing channel (never overwritten once set).
  attributionChannel   String?
  attributionSource    String?
  attributionMedium    String?
  attributionCampaign  String?
  attributionTerm      String?
  attributionContent   String?
  gclid                String?
  fbclid               String?
  msclkid              String?
  firstTouchAt         DateTime?
  firstTouchMethod     AttributionFirstTouchMethod?
  referredByCustomerId String?
  stripeCustomerId String?
