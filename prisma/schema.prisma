model CallLog {
  id            String        @id @default(cuid())
  companyId     String
  scope         Scope
  direction     CallDirection
  fromNumber    String
  toNumber      String
  customerId    String?
  userId        String?
  sessionId     String?
  conferenceSid String?
  queueWaitSec  Int?
  twilioCallSid String        @unique
  status        String
  durationSec   Int?
  recordingUrl  String?
  transcript    String?
  /// One-paragraph AI summary generated from the transcript.
  aiSummary     String?
  disposition   CallDisposition @default(NONE)
  dispositionNote String?
  visitId       String?
  leadId        String?
  handledByUserId String?
  /// Dialed company Twilio number (inbound tracking / primary).
  phoneNumberId String?
  /// Copied from PhoneNumber.trackingSource when known (e.g. "Google Ads", "Yard sign").
  trackingSource String?
  attributionMethod CallAttributionMethod @default(UNKNOWN)
  /// Matched Google Local Services lead id when attribution is LSA_CALLER_MATCH.
  googleLsaLeadId String?
  startedAt     DateTime      @default(now())
  endedAt       DateTime?

  company  Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)
  user     User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  session  CallSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  visit    Visit?       @relation("CallLogVisit", fields: [visitId], references: [id], onDelete: SetNull)
  lead     Lead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)
  handledBy User?       @relation("HandledCallLogs", fields: [handledByUserId], references: [id], onDelete: SetNull)
  phoneNumber PhoneNumber? @relation(fields: [phoneNumberId], references: [id], onDelete: SetNull)
  conversion CallConversion?
  visitNotes VisitNote[]
  participants CallParticipant[]

  @@index([companyId, scope, startedAt])
  @@index([sessionId])
  @@index([disposition])
  @@index([companyId, attributionMethod, startedAt])
  @@index([companyId, fromNumber, startedAt])
  @@index([companyId, customerId, startedAt])
  @@index([googleLsaLeadId])
}

/// First-party call → booking conversion (CSR, attribution, linked appointment/revenue).
model CallConversion {
  id                String                @id @default(cuid())
  companyId         String
  callLogId         String                @unique
  callSessionId     String?
  answeredByUserId  String?
  disposition       CallDisposition       @default(NONE)
  booked            Boolean               @default(false)
  visitId           String?
  attributionMethod CallAttributionMethod @default(UNKNOWN)
  phoneNumberId     String?
  trackingSource    String?
  googleLsaLeadId   String?
  callerNumber      String
  dialedNumber      String
  customerId        String?
  /// Snapshot of linked visit revenue (line items − discounts) when available.
  revenueAmount     Decimal?              @db.Decimal(12, 2)
  convertedAt       DateTime?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  company       Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  callLog       CallLog      @relation(fields: [callLogId], references: [id], onDelete: Cascade)
  callSession   CallSession? @relation(fields: [callSessionId], references: [id], onDelete: SetNull)
  answeredBy    User?        @relation("AnsweredCallConversions", fields: [answeredByUserId], references: [id], onDelete: SetNull)
  visit         Visit?       @relation(fields: [visitId], references: [id], onDelete: SetNull)
  phoneNumber   PhoneNumber? @relation(fields: [phoneNumberId], references: [id], onDelete: SetNull)
  customer      Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([companyId, booked, convertedAt])
  @@index([companyId, attributionMethod, convertedAt])
  @@index([companyId, trackingSource, convertedAt])
  @@index([answeredByUserId, convertedAt])
  @@index([visitId])
  @@index([googleLsaLeadId])
}

