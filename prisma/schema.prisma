model ReferralReward {
  id                   String               @id @default(cuid())
  submissionId         String               @unique
  amountCents          Int
  status               ReferralRewardStatus @default(PENDING_ONBOARDING)
  stripeTransferId     String?
  failureReason        String?
  paidAt               DateTime?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  submission ReferralSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([status])
}

model PropertyIrrigationMapZone {
  id                  String   @id @default(cuid())
  propertyId          String
  name                String
  polygonGeoJson      Json
  vegetationType      String?
  shadeLevel          String?
  slopeLevel          String?
  soilType            String?
  irrigationType      String?
  nozzleCount         Int?
  estimatedGpm        Float?
  baseRuntimeMinutes  Int?
  irrigatedSqFt           Int?
  irrigationEfficiencyScore Int?
  establishmentStage      ZoneEstablishmentStage @default(NORMAL)
  nozzleGpm               Float?
  computedWeeklyRuntimeMinutes Int?
  computedGallonsPerWeek       Float?
  designVersionId     String?
  sortOrder           Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  property CustomerProperty @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  zoneStations PropertyZoneStation[]

