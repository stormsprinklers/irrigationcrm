model PropertyIrrigationController {
  id                String   @id @default(cuid())
  propertyId        String
  label             String
  pointGeoJson      Json
  stationCount      Int      @default(1)
  controllerModelId String?
  sortOrder         Int      @default(0)
  createdAt         DateTime @default(now())
