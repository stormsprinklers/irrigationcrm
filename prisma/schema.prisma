  selectedAddonIds        String[]          @default([])
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt

  company      Company                       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer     Customer                      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  property     CustomerProperty              @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  template     MaintenancePlanTemplate       @relation(fields: [templateId], references: [id])
  planVisits   MaintenancePlanVisit[]
  billingPeriods MaintenancePlanBillingPeriod[]

  @@index([companyId, status])
  @@index([customerId])
  @@index([propertyId])
  @@map("PropertyMaintenancePlan")
}

model MaintenancePlanVisit {
  id              String          @id @default(cuid())
  enrollmentId    String
  visitTemplateId String?
  dueYear         Int
  dueMonth        Int
  status          PlanVisitStatus @default(UNSCHEDULED)
  completedAt     DateTime?
  notes           String?

  enrollment    MaintenancePlanEnrollment     @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  visitTemplate MaintenancePlanVisitTemplate? @relation(fields: [visitTemplateId], references: [id], onDelete: SetNull)
  visit         Visit?

  @@index([enrollmentId, dueYear, dueMonth])
  @@index([status])
}

model MaintenancePlanBillingPeriod {
  id                    String              @id @default(cuid())
  enrollmentId          String
  periodStart           DateTime
  periodEnd             DateTime
  amount                Decimal             @db.Decimal(10, 2)
  status                BillingPeriodStatus @default(PENDING)
  dueDate               DateTime
  paidAt                DateTime?
  invoiceId             String?
  stripePaymentIntentId  String?

  enrollment MaintenancePlanEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  invoice    Invoice?                  @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([enrollmentId, dueDate])
  @@index([status])
}

model PropertySmartController {
  id                String                  @id @default(cuid())
  propertyId        String
  provider          SmartControllerProvider
  externalDeviceId  String?
  externalAccountId String?
  status            SmartControllerStatus   @default(DISCONNECTED)
  lastSyncedAt      DateTime?
  metadata          Json?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  property CustomerProperty @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([propertyId, provider])
  @@index([propertyId])
}

model PriceBookDiscount {
  id        String                   @id @default(cuid())
  companyId String
  name      String
  code      String?
  type      DiscountType
  amount    Decimal                  @db.Decimal(10, 2)
  active    Boolean                  @default(true)
  appliesTo PriceBookDiscountAppliesTo @default(ALL)
  createdAt DateTime                 @default(now())
  updatedAt DateTime                 @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, active])
}

model EstimateTemplate {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company   Company                    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lineItems EstimateTemplateLineItem[]

  @@index([companyId])
}

model EstimateTemplateLineItem {
  id              String  @id @default(cuid())
  templateId      String
  priceBookItemId String?
  name            String
  description     String?
  quantity        Decimal @default(1) @db.Decimal(10, 2)
  unitPrice       Decimal @db.Decimal(10, 2)
  sortOrder       Int     @default(0)

  template      EstimateTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  priceBookItem PriceBookItem?   @relation(fields: [priceBookItemId], references: [id], onDelete: SetNull)

  @@index([templateId])
}

model PricingForm {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  description String?
  fields      Json
  categoryId  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company  Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  category PriceBookCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([companyId])
}

model HousecallProMigration {
  id           String                        @id @default(cuid())
  companyId    String
  status       HousecallProMigrationStatus   @default(DRAFT)
  currentStep  HousecallProMigrationStepType @default(CONNECT)
  previewJson  Json?
  optionsJson  Json?
  startedAt    DateTime?
  pausedAt     DateTime?
  completedAt  DateTime?
  createdAt    DateTime                      @default(now())
  updatedAt    DateTime                      @updatedAt

  company  Company                     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  steps    HousecallProMigrationStep[]
  mappings HcpEntityMapping[]

  @@index([companyId, status])
}

model HousecallProMigrationStep {
  id            String                          @id @default(cuid())
  migrationId   String
  step          HousecallProMigrationStepType
  status        HousecallProMigrationStepStatus @default(PENDING)
  cursor        String?
  processed     Int                             @default(0)
  created       Int                             @default(0)
  updated       Int                             @default(0)
  skipped       Int                             @default(0)
  failed        Int                             @default(0)
  totalEstimate Int?
  lastError     String?
  statsJson     Json?
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime                        @default(now())
  updatedAt     DateTime                        @updatedAt

  migration HousecallProMigration @relation(fields: [migrationId], references: [id], onDelete: Cascade)

  @@unique([migrationId, step])
  @@index([migrationId, status])
}

model HcpEntityMapping {
  id           String        @id @default(cuid())
  companyId    String
  migrationId  String?
  entityType   HcpEntityType
  hcpId        String
  localId      String
  metadataJson Json?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  company   Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  migration HousecallProMigration? @relation(fields: [migrationId], references: [id], onDelete: SetNull)

  @@unique([companyId, entityType, hcpId])
  @@index([companyId, entityType, localId])
  @@index([migrationId])
}

model ChecklistTemplate {
  id                    String     @id @default(cuid())
  companyId             String
  name                  String
  description           String?
  active                Boolean    @default(true)
  applyToAllJobs        Boolean    @default(false)
  divisions             Division[] @default([])
  excludeCallbacks      Boolean    @default(false)
  requiredForCompletion Boolean    @default(false)
  customerVisible       Boolean    @default(false)
  sortOrder             Int        @default(0)
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  company      Company                     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  items        ChecklistItemTemplate[]
  lineItemLinks ChecklistTemplateLineItem[]
  visitChecklists VisitChecklist[]

  @@index([companyId, active, sortOrder])
}

model ChecklistItemTemplate {
  id         String            @id @default(cuid())
  templateId String
  label      String
  helpText   String?
  type       ChecklistItemType
  required   Boolean           @default(false)
  sortOrder  Int               @default(0)
  options    Json?
  config     Json?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  template ChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId, sortOrder])
}

model ChecklistTemplateLineItem {
  id              String @id @default(cuid())
  templateId      String
  priceBookItemId String

  template      ChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  priceBookItem PriceBookItem     @relation(fields: [priceBookItemId], references: [id], onDelete: Cascade)

  @@unique([templateId, priceBookItemId])
  @@index([priceBookItemId])
}

model VisitChecklist {
  id                    String               @id @default(cuid())
  visitId               String
  templateId            String?
  name                  String
  requiredForCompletion Boolean              @default(false)
  status                VisitChecklistStatus @default(NOT_STARTED)
  appliedAt             DateTime             @default(now())
  completedAt           DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  visit    Visit                 @relation(fields: [visitId], references: [id], onDelete: Cascade)
  template ChecklistTemplate?    @relation(fields: [templateId], references: [id], onDelete: SetNull)
  items    VisitChecklistItem[]

  @@unique([visitId, templateId])
  @@index([visitId])
}

model VisitChecklistItem {
  id               String            @id @default(cuid())
  visitChecklistId String
  label            String
  helpText         String?
  type             ChecklistItemType
  required         Boolean           @default(false)
  sortOrder        Int               @default(0)
  options          Json?
  config           Json?
  response         Json?
  completedAt      DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  visitChecklist VisitChecklist @relation(fields: [visitChecklistId], references: [id], onDelete: Cascade)

  @@index([visitChecklistId, sortOrder])
}

model CustomerPortalLoginToken {
