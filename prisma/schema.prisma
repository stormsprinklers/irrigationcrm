generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  CSR
  TECH
}

enum Scope {
  EXTERNAL
  INTERNAL
}

enum Channel {
  SMS
  INTERNAL_CHAT
  EMAIL
}

enum CallDirection {
  INBOUND
  OUTBOUND
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum EmailFolder {
  INBOX
  SENT
  DRAFT
  ARCHIVE
  SPAM
  TRASH
}

enum Division {
  INSTALL
  SERVICE
}

enum EmployeeStatus {
  ACTIVE
  ARCHIVED
}

enum VisitStatus {
  UNSCHEDULED
  SCHEDULED
  EN_ROUTE
  IN_PROGRESS
  PAUSED
  COMPLETED
  CANCELLED
}

enum TimeEventType {
  EN_ROUTE
  START
  PAUSE
  RESUME
  FINISH
}

enum EstimateStatus {
  DRAFT
  SENT
  APPROVED
  EXPIRED
  DECLINED
  CONVERTED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  PARTIAL
  REFUNDED
  VOID
}

enum DiscountType {
  PERCENT
  FIXED
}

enum DepositType {
  PERCENT
  FIXED
}

enum PaymentMethod {
  STRIPE
  CASH
  CHECK
  OTHER
}

model Company {
  id                       String   @id @default(cuid())
  name                     String
  twilioPhone              String?
  sendgridFrom             String?
  sendgridInboundDomain    String?
  recordCalls              Boolean  @default(true)
  transcribeCalls          Boolean  @default(true)
  estimateExpiryDays       Int      @default(14)
  estimateDepositRequired  Boolean  @default(false)
  estimateDepositType      DepositType?
  estimateDepositAmount    Decimal? @db.Decimal(10, 2)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  users             User[]
  customers         Customer[]
  blockedContacts   BlockedContact[]
  callLogs          CallLog[]
  conversations     Conversation[]
  emailMessages     EmailMessage[]
  internalGroups    InternalGroup[]
  serviceAreas      ServiceArea[]
  crews             Crew[]
  visits            Visit[]
  properties        CustomerProperty[]
  priceBookCategories PriceBookCategory[]
  estimates         Estimate[]
  invoices          Invoice[]
  maintenancePlans  MaintenancePlan[]
}

model User {
  id           String         @id @default(cuid())
  companyId    String
  name         String
  email        String         @unique
  passwordHash String?
  phone        String?
  role         UserRole       @default(CSR)
  title        String?
  status       EmployeeStatus @default(ACTIVE)
  division     Division?
  color        String?
  photoUrl     String?
  address      String?
  city         String?
  state        String?
  zip          String?
  birthDate    DateTime?
  tags         String[]       @default([])
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  company            Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  callLogs           CallLog[]
  sentMessages       Message[]
  emailMessages      EmailMessage[]
  blockedContacts    BlockedContact[]     @relation("BlockedByUser")
  groupMemberships   InternalGroupMember[]
  serviceAreas       UserServiceArea[]
  crewMemberships    CrewMember[]
  assignedVisits     Visit[]              @relation("AssignedVisits")
  visitTimeEvents    VisitTimeEvent[]
  visitNotes         VisitNote[]
  visitAttachments   VisitAttachment[]
}

model Customer {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  phone       String?
  email       String?
  companyName String?
  address     String?
  city        String?
  state       String?
  zip         String?
  leadSource  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company       Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  blockedEntry  BlockedContact?
  callLogs      CallLog[]
  conversations Conversation[]
  emailMessages EmailMessage[]
  properties    CustomerProperty[]
  visits        Visit[]
  estimates     Estimate[]
  invoices      Invoice[]
}

model CustomerProperty {
  id         String   @id @default(cuid())
  companyId  String
  customerId String
  name       String
  address    String?
  city       String?
  state      String?
  zip        String?
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  company          Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer         Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  visits           Visit[]
  estimates        Estimate[]
  maintenancePlans PropertyMaintenancePlan[]

  @@index([companyId, customerId])
}

model BlockedContact {
  id         String   @id @default(cuid())
  companyId  String
  customerId String?  @unique
  phone      String?
  email      String?
  blockedAt  DateTime @default(now())
  blockedBy  String
  reason     String?

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  user     User      @relation("BlockedByUser", fields: [blockedBy], references: [id])

  @@index([companyId, phone])
  @@index([companyId, email])
}

model CallLog {
  id            String        @id @default(cuid())
  companyId     String
  scope         Scope
  direction     CallDirection
  fromNumber    String
  toNumber      String
  customerId    String?
  userId        String?
  twilioCallSid String        @unique
  status        String
  durationSec   Int?
  recordingUrl  String?
  transcript    String?
  startedAt     DateTime      @default(now())
  endedAt       DateTime?

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  user     User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([companyId, scope, startedAt])
}

model Conversation {
  id               String   @id @default(cuid())
  companyId        String
  channel          Channel
  scope            Scope
  customerId       String?
  participantPhone String?
  title            String?
  lastMessageAt    DateTime @default(now())
  createdAt        DateTime @default(now())

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  messages Message[]

  @@index([companyId, channel, scope, lastMessageAt])
}

model Message {
  id               String           @id @default(cuid())
  conversationId   String
  senderId         String?
  direction        MessageDirection
  body             String
  twilioMessageSid String?          @unique
  sentAt           DateTime         @default(now())
  readAt           DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User?        @relation(fields: [senderId], references: [id], onDelete: SetNull)

  @@index([conversationId, sentAt])
}

model EmailMessage {
  id         String      @id @default(cuid())
  companyId  String
  scope      Scope
  folder     EmailFolder @default(INBOX)
  fromEmail  String
  toEmails   String[]
  ccEmails   String[]    @default([])
  subject    String
  bodyHtml   String?
  bodyText   String?
  customerId String?
  userId     String?
  sendgridId String?
  threadId   String?
  isRead     Boolean     @default(false)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  user     User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([companyId, scope, folder, createdAt])
}

model InternalGroup {
  id        String   @id @default(cuid())
  companyId String
  name      String
  createdAt DateTime @default(now())

  company Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  members InternalGroupMember[]
}

model InternalGroupMember {
  id      String @id @default(cuid())
  groupId String
  userId  String

  group InternalGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
}

model ServiceArea {
  id        String   @id @default(cuid())
  companyId String
  name      String
  slug      String
  color     String   @default("#2563EB")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  zips    ServiceAreaZip[]
  users   UserServiceArea[]
  visits  Visit[]

  @@unique([companyId, slug])
  @@index([companyId, sortOrder])
}

model ServiceAreaZip {
  id            String @id @default(cuid())
  serviceAreaId String
  zipCode       String

  serviceArea ServiceArea @relation(fields: [serviceAreaId], references: [id], onDelete: Cascade)

  @@unique([serviceAreaId, zipCode])
  @@index([zipCode])
}

model UserServiceArea {
  id            String @id @default(cuid())
  userId        String
  serviceAreaId String

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  serviceArea ServiceArea @relation(fields: [serviceAreaId], references: [id], onDelete: Cascade)

  @@unique([userId, serviceAreaId])
}

model Crew {
  id        String    @id @default(cuid())
  companyId String
  name      String
  color     String    @default("#16A34A")
  division  Division?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  company Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  members CrewMember[]
  visits  Visit[]

  @@index([companyId])
}

model CrewMember {
  id     String @id @default(cuid())
  crewId String
  userId String

  crew Crew @relation(fields: [crewId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([crewId, userId])
}

model Visit {
  id             String      @id @default(cuid())
  companyId      String
  customerId     String?
  propertyId     String?
  title          String
  startAt        DateTime
  endAt          DateTime
  division       Division
  serviceAreaId  String
  assignedUserId String?
  crewId         String?
  status         VisitStatus @default(SCHEDULED)
  tags           String[]    @default([])
  address        String?
  city           String?
  state          String?
  zip            String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  company      Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer     Customer?         @relation(fields: [customerId], references: [id], onDelete: SetNull)
  property     CustomerProperty? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  serviceArea  ServiceArea       @relation(fields: [serviceAreaId], references: [id])
  assignedUser User?             @relation("AssignedVisits", fields: [assignedUserId], references: [id], onDelete: SetNull)
  crew         Crew?             @relation(fields: [crewId], references: [id], onDelete: SetNull)
  timeEvents   VisitTimeEvent[]
  lineItems    VisitLineItem[]
  notes        VisitNote[]
  attachments  VisitAttachment[]
  discounts    Discount[]        @relation("VisitDiscounts")
  estimates    Estimate[]
  invoices     Invoice[]

  @@index([companyId, startAt])
  @@index([serviceAreaId])
  @@index([assignedUserId])
  @@index([crewId])
  @@index([customerId])
  @@map("ScheduledJob")
}

model VisitTimeEvent {
  id         String        @id @default(cuid())
  visitId    String
  userId     String
  type       TimeEventType
  occurredAt DateTime      @default(now())

  visit Visit @relation(fields: [visitId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([visitId, occurredAt])
}

model VisitLineItem {
  id              String   @id @default(cuid())
  visitId         String
  priceBookItemId String?
  name            String
  description     String?
  quantity        Decimal  @default(1) @db.Decimal(10, 2)
  unitPrice       Decimal  @db.Decimal(10, 2)
  total           Decimal  @db.Decimal(10, 2)
  sortOrder       Int      @default(0)

  visit         Visit          @relation(fields: [visitId], references: [id], onDelete: Cascade)
  priceBookItem PriceBookItem? @relation(fields: [priceBookItemId], references: [id], onDelete: SetNull)

  @@index([visitId])
}

model VisitNote {
  id        String   @id @default(cuid())
  visitId   String
  authorId  String
  body      String
  createdAt DateTime @default(now())

  visit  Visit @relation(fields: [visitId], references: [id], onDelete: Cascade)
  author User  @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([visitId, createdAt])
}

model VisitAttachment {
  id           String   @id @default(cuid())
  visitId      String
  uploadedById String
  blobUrl      String
  fileName     String
  mimeType     String
  createdAt    DateTime @default(now())

  visit      Visit @relation(fields: [visitId], references: [id], onDelete: Cascade)
  uploadedBy User  @relation(fields: [uploadedById], references: [id], onDelete: Cascade)

  @@index([visitId])
}

model Discount {
  id         String       @id @default(cuid())
  visitId    String?
  estimateId String?
  label      String?
  type       DiscountType
  amount     Decimal      @db.Decimal(10, 2)

  visit    Visit?    @relation("VisitDiscounts", fields: [visitId], references: [id], onDelete: Cascade)
  estimate Estimate? @relation("EstimateDiscounts", fields: [estimateId], references: [id], onDelete: Cascade)

  @@index([visitId])
  @@index([estimateId])
}

model PriceBookCategory {
  id        String   @id @default(cuid())
  companyId String
  name      String
  slug      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  items   PriceBookItem[]

  @@unique([companyId, slug])
  @@index([companyId, sortOrder])
}

model PriceBookItem {
  id          String   @id @default(cuid())
  categoryId  String
  name        String
  description String?
  unitPrice   Decimal  @db.Decimal(10, 2)
  unit        String   @default("each")
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category           PriceBookCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  visitLineItems     VisitLineItem[]
  estimateLineItems  EstimateLineItem[]

  @@index([categoryId, active])
}

model Estimate {
  id              String         @id @default(cuid())
  companyId       String
  customerId      String
  propertyId      String?
  visitId         String?
  status          EstimateStatus @default(DRAFT)
  expiresAt       DateTime?
  depositRequired Boolean        @default(false)
  depositType     DepositType?
  depositAmount   Decimal?       @db.Decimal(10, 2)
  signatureBlobUrl String?
  signedAt        DateTime?
  approvedAt      DateTime?
  subtotal        Decimal        @default(0) @db.Decimal(10, 2)
  discountTotal   Decimal        @default(0) @db.Decimal(10, 2)
  total           Decimal        @default(0) @db.Decimal(10, 2)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  company     Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer    Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  property    CustomerProperty? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  visit       Visit?            @relation(fields: [visitId], references: [id], onDelete: SetNull)
  lineItems   EstimateLineItem[]
  notes       EstimateNote[]
  attachments EstimateAttachment[]
  discounts   Discount[]        @relation("EstimateDiscounts")
  invoices    Invoice[]

  @@index([companyId, status])
  @@index([customerId])
  @@index([visitId])
}

model EstimateLineItem {
  id              String  @id @default(cuid())
  estimateId      String
  priceBookItemId String?
  name            String
  description     String?
  quantity        Decimal @default(1) @db.Decimal(10, 2)
  unitPrice       Decimal @db.Decimal(10, 2)
  total           Decimal @db.Decimal(10, 2)
  sortOrder       Int     @default(0)

  estimate      Estimate       @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  priceBookItem PriceBookItem? @relation(fields: [priceBookItemId], references: [id], onDelete: SetNull)

  @@index([estimateId])
}

model EstimateNote {
  id         String   @id @default(cuid())
  estimateId String
  authorId   String
  body       String
  createdAt  DateTime @default(now())

  estimate Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)

  @@index([estimateId, createdAt])
}

model EstimateAttachment {
  id         String   @id @default(cuid())
  estimateId String
  blobUrl    String
  fileName   String
  mimeType   String
  createdAt  DateTime @default(now())

  estimate Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)

  @@index([estimateId])
}

model Invoice {
  id                      String        @id @default(cuid())
  companyId               String
  customerId              String
  visitId                 String?
  estimateId              String?
  invoiceNumber           String
  status                  InvoiceStatus @default(DRAFT)
  subtotal                Decimal       @default(0) @db.Decimal(10, 2)
  discountTotal           Decimal       @default(0) @db.Decimal(10, 2)
  tax                     Decimal       @default(0) @db.Decimal(10, 2)
  total                   Decimal       @default(0) @db.Decimal(10, 2)
  paidAt                  DateTime?
  publicToken             String        @unique @default(cuid())
  stripeCheckoutSessionId String?
  stripePaymentIntentId   String?
  sentAt                  DateTime?
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt

  company   Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer  Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  visit     Visit?            @relation(fields: [visitId], references: [id], onDelete: SetNull)
  estimate  Estimate?         @relation(fields: [estimateId], references: [id], onDelete: SetNull)
  lineItems InvoiceLineItem[]
  payments  Payment[]

  @@unique([companyId, invoiceNumber])
  @@index([companyId, status])
  @@index([customerId])
}

model InvoiceLineItem {
  id          String  @id @default(cuid())
  invoiceId   String
  name        String
  description String?
  quantity    Decimal @default(1) @db.Decimal(10, 2)
  unitPrice   Decimal @db.Decimal(10, 2)
  total       Decimal @db.Decimal(10, 2)
  sortOrder   Int     @default(0)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model Payment {
  id                    String        @id @default(cuid())
  invoiceId             String
  amount                Decimal       @db.Decimal(10, 2)
  method                PaymentMethod @default(STRIPE)
  stripePaymentIntentId String?
  stripeRefundId        String?
  paidAt                DateTime      @default(now())
  refundedAt            DateTime?

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model MaintenancePlan {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company    Company                   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  properties PropertyMaintenancePlan[]

  @@index([companyId])
}

model PropertyMaintenancePlan {
  id         String   @id @default(cuid())
  propertyId String
  planId     String
  startDate  DateTime @default(now())
  active     Boolean  @default(true)

  property CustomerProperty @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  plan     MaintenancePlan    @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([propertyId, planId])
}
