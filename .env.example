# Database
DATABASE_URL="postgresql://user:password@localhost:5432/irrigationcrm?schema=public"

# Auth
NEXTAUTH_SECRET="generate-a-long-random-secret"
NEXTAUTH_URL="http://localhost:3000"
# If unset locally, a dev-only fallback secret is used temporarily — set NEXTAUTH_SECRET before production.

# Vercel Blob (employee photos) — required on Vercel Production/Preview
BLOB_STORE_ID=
BLOB_READ_WRITE_TOKEN=

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_API_KEY=
TWILIO_API_SECRET=
TWILIO_PHONE_NUMBER=
TWILIO_TWIML_APP_SID=

# SendGrid
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=support@stormsprinklers.com
SENDGRID_INBOUND_DOMAIN=
SENDGRID_WEBHOOK_SECRET=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe (visit checkout, estimate deposits, refunds, maintenance plan subscriptions)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Webhook URL: POST /api/stripe/webhook (must be public; excluded from auth middleware)
# Events: checkout.session.completed, payment_intent.succeeded, invoice.paid,
# invoice.payment_failed, customer.subscription.deleted, customer.subscription.updated
