# Database
DATABASE_URL="postgresql://user:password@localhost:5432/irrigationcrm?schema=public"

# Auth — required in production (Auth.js accepts AUTH_SECRET or NEXTAUTH_SECRET)
AUTH_SECRET="generate-a-long-random-secret"
NEXTAUTH_SECRET="generate-a-long-random-secret"
# Shared secret for LMS auth tickets after SMS 2FA (defaults to LMS_INTEGRATION_KEY)
STAFF_AUTH_TICKET_SECRET=""
# Local/dev only: include OTP in API responses and log reset links
# STAFF_AUTH_EXPOSE_OTP="true"

# Mobile app (Storm CRM iOS) — bearer token auth for field technicians
# MOBILE_JWT_SECRET defaults to AUTH_SECRET when unset
MOBILE_JWT_SECRET=""
MOBILE_REFRESH_DAYS=30

# Apple Push Notifications (Storm CRM iOS SMS alerts)
# Create an APNs Auth Key (.p8) in Apple Developer → Keys
APNS_KEY_ID=""
APNS_TEAM_ID=""
# Paste the .p8 contents; use \n for line breaks in env files
APNS_PRIVATE_KEY=""
APNS_BUNDLE_ID="com.stormsprinklers.stormcrm"
# Set to true for Xcode debug builds (sandbox APNs)
APNS_USE_SANDBOX="false"

# Web Push (Radar PWA — iOS Home Screen + desktop browsers)
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
# mailto: or https: contact URI required by the Web Push protocol
VAPID_SUBJECT="mailto:support@stormsprinklers.com"

NEXTAUTH_URL="http://localhost:3000"

# Vercel Blob (employee photos, voice clips) — required on Vercel Production/Preview
BLOB_STORE_ID=
BLOB_READ_WRITE_TOKEN=

# Twilio (voice, SMS, and email)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_API_KEY=
TWILIO_API_SECRET=
TWILIO_PHONE_NUMBER=
TWILIO_TWIML_APP_SID=
# Push Credential SIDs for ringing mobile apps on incoming calls (Twilio Console → Voice → Push Credentials)
# iOS uses an APNs VoIP certificate; Android uses an FCM server key.
TWILIO_PUSH_CREDENTIAL_SID=
TWILIO_ANDROID_PUSH_CREDENTIAL_SID=
# Verified sender for outbound email (Twilio Email API)
TWILIO_FROM_EMAIL=support@stormsprinklers.com
# Optional dedicated Email API key (Main or Standard with Email permission)
TWILIO_EMAIL_API_KEY=
TWILIO_EMAIL_API_SECRET=
# Optional — inbound parse webhook token (?token=...)
TWILIO_EMAIL_INBOUND_VERIFY_TOKEN=
# Optional — ECDSA public key for signed email event webhooks
TWILIO_EMAIL_WEBHOOK_PUBLIC_KEY=

# Legacy fallbacks (optional — prefer TWILIO_FROM_EMAIL)
SENDGRID_FROM_EMAIL=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_LMS_URL=http://localhost:3001
NEXT_PUBLIC_DESIGN_URL=http://localhost:3002
NEXT_PUBLIC_WEBSITE_URL=http://localhost:3003

# Outbound integrations (server only)
LMS_INTEGRATION_URL=http://localhost:3001
LMS_INTEGRATION_KEY=

# Integration hub — spokes call POST /api/integrations/* with Bearer keys
# Generate keys in Settings → Integrations (WEBSITE, LMS, DESIGN, MAPS types)
# Spoke env (website, design, lms):
# CRM_INTEGRATION_URL=http://localhost:3000/api/integrations
# CRM_INTEGRATION_KEY=crm_int_...

# Google Maps (server-only — embed, static satellite, geocoding, distance matrix, places)
GOOGLE_MAPS_API_KEY=
# Enable Maps Embed API, Maps Static API, Geocoding API, Distance Matrix API, and Places API (New) — including Place Autocomplete — on this key in Google Cloud Console

# Google OAuth — Search Console, Google Ads, and other non-GBP integrations
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Optional: Search Console domain verification meta tag for crm.stormsprinklers.com homepage
GOOGLE_SITE_VERIFICATION=
# Add redirect URIs on this OAuth client:
#   {NEXT_PUBLIC_APP_URL}/api/marketing/search-console/callback
#   {NEXT_PUBLIC_APP_URL}/api/marketing/google-ads/callback
# OAuth scopes (add on consent screen):
#   https://www.googleapis.com/auth/webmasters.readonly  (Search Console)
#   https://www.googleapis.com/auth/adwords              (Google Ads)
# Enable APIs: Search Console API, Google Ads API
# Aliases GOOGLE_CLOUD_CLIENT_ID / GOOGLE_CLOUD_CLIENT_SECRET are also supported.

# Google Business Profile OAuth (optional separate OAuth client)
GOOGLE_BUSINESS_OAUTH_CLIENT_ID=
GOOGLE_BUSINESS_OAUTH_CLIENT_SECRET=
# If unset, GBP falls back to GOOGLE_OAUTH_CLIENT_ID / GOOGLE_OAUTH_CLIENT_SECRET.
# Add redirect URI on the GBP OAuth client:
#   {NEXT_PUBLIC_APP_URL}/api/marketing/google-business/callback
# Google Ads developer token (Vercel — server only):
GOOGLE_ADS_DEVELOPER_TOKEN=
# Optional: Google Ads API major version (default v24; v18 was sunset Aug 2025)
# GOOGLE_ADS_API_VERSION=v24
# Note: GA4 CRM OAuth (analytics.readonly) is deprecated — website analytics are native. See lib/google-analytics/DEPRECATED.md

# SerpAPI (Marketing → Google Business Profile local rankings)
SERPAPI_API_KEY=
# Free plan defaults: 50 google_local searches/hour, 250/month (enforced app-side)
SERPAPI_HOURLY_LIMIT=50
SERPAPI_MONTHLY_LIMIT=250
SERPAPI_CACHE_TTL_HOURS=24

# Meta (Facebook / Instagram)
# Vercel (required):
NEXT_PUBLIC_APP_URL=https://your-crm.example.com
# Vercel (optional — default App ID shown in Settings → Meta webhooks if not set per company):
META_APP_ID=
# Webhook URL (paste in Meta Developer Console): {NEXT_PUBLIC_APP_URL}/api/meta/webhook
# Per-company in CRM (Settings → Meta webhooks — NOT in Vercel):
#   Verify token (you generate in CRM), App Secret, App ID, Facebook Page ID, Instagram account ID

# OpenAI (price book AI descriptions & images, Marketing SEO recommendations, AI receptionist)
OPENAI_API_KEY=

# AI receptionist (Twilio Media Streams ↔ OpenAI Realtime via sideband worker)
# Public WSS URL of the sideband service, e.g. wss://receptionist.example.com/twilio/media
SIDEBAND_PUBLIC_WSS_URL=
# Shared HMAC secret for stream/tool tokens (falls back to NEXTAUTH_SECRET)
AI_RECEPTIONIST_SECRET=

# Slack (Google review alert cards — bot needs chat:write + files:write; invite bot to channel)
SLACK_BOT_TOKEN=

# Housecall Pro migration (read-only import; server only)
HOUSECALL_PRO_API_KEY=

# Stripe (visit checkout, invoice pay links, refunds, maintenance plan subscriptions)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# STRIPE_PLATFORM_ACCOUNT_ID — acct_... for your Connect platform (referral payouts)
STRIPE_PLATFORM_ACCOUNT_ID=
# STRIPE_CONNECT_CLIENT_ID — ca_... from Stripe Connect settings (optional OAuth)
STRIPE_CONNECT_CLIENT_ID=
# STRIPE_SECRET_KEY — sk_test_... or sk_live_... (server only, never expose)
# STRIPE_PUBLISHABLE_KEY — pk_test_... or pk_live_... (safe for Stripe.js in the browser)
# Stripe Dashboard → Developers → API keys
# Webhook signing secret (whsec_...) from Stripe Dashboard → Developers → Webhooks
# Webhook URL: POST /api/stripe/webhook (must be public; excluded from auth middleware)
# Customer pay page: /pay/[token] (linked from invoice emails)
# Events: checkout.session.completed, invoice.paid, invoice.payment_failed,
# customer.subscription.deleted, customer.subscription.updated
